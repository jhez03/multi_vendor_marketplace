{% extends 'base.html.twig' %}
{% block title %}Marketplace — Buy & Sell{% endblock %}
{% block body %}
    <div class="relative overflow-hidden">
        {% include 'partials/_header.html.twig' %}
        <main class="relative z-10">
            {# ── Hero ──────────────────────────────────────────────────────── #}
            <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
                <div class="grid gap-10 py-14 lg:grid-cols-12 lg:items-center lg:py-20">
                    <div class="lg:col-span-7">
                        <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-xs text-slate-200 ring-1 ring-white/10">
                            <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
                            Trusted by independent sellers worldwide
                        </div>
                        <h1 class="mt-5 text-4xl font-semibold tracking-tight sm:text-5xl">
                            Discover unique products from
                            <span class="bg-gradient-to-r from-fuchsia-300 to-cyan-200 bg-clip-text text-transparent">verified sellers</span>
                        </h1>
                        <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">
                            A modern multi-vendor marketplace with fast checkout, secure payments, and seller tools built for growth.
                        </p>
                        {# ── Search bar ──────────────────────────────────────── #}
                        <div class="mt-8">
                            <div data-controller="market-search"
                                 data-market-search-url-value="{{ path("app_search") }}"
                                 class="flex flex-col gap-3 rounded-2xl bg-white/5 p-4 ring-1 ring-white/10 focus-within:ring-amber-500/30 transition-all duration-200 sm:flex-row sm:items-center">
                                <div class="hidden sm:block text-slate-500 shrink-0 pl-1">
                                    <svg class="w-4 h-4"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="2">
                                        <circle cx="11" cy="11" r="8" />
                                        <path d="m21 21-4.35-4.35" />
                                    </svg>
                                </div>
                                <div class="flex-1 relative">
                                    <label class="sr-only" for="homepage-search">Search</label>
                                    <input id="homepage-search"
                                           data-market-search-target="input"
                                           data-action="input->market-search#onInput keydown.enter->market-search#submit"
                                           type="search"
                                           name="q"
                                           placeholder="Search products, brands, stores…"
                                           maxlength="200"
                                           autocomplete="off"
                                           spellcheck="false"
                                           class="w-full rounded-xl bg-slate-900/70 px-4 py-3 text-sm text-slate-100 placeholder:text-slate-400 ring-1 ring-white/10 outline-none focus:ring-2 focus:ring-amber-400/60 transition-all">
                                </div>
                                <div class="flex gap-2">
                                    <button type="button"
                                            data-action="click->market-search#submit"
                                            class="rounded-xl bg-cyan-400 px-4 py-3 text-sm font-semibold text-slate-950 hover:bg-cyan-300 transition-colors cursor-pointer">
                                        Search
                                    </button>
                                    <a href="{{ path("register_seller") }}"
                                       class="rounded-xl bg-white/10 px-4 py-3 text-sm font-semibold text-white hover:bg-white/15 ring-1 ring-white/10 no-underline">
                                        Become a seller
                                    </a>
                                </div>
                            </div>
                            <p class="mt-3 text-xs text-slate-400">Tip: try "handmade", "electronics", or "home decor".</p>
                        </div>
                    </div>
                    {# ── Hero side cards ───────────────────────────────────── #}
                    <div class="lg:col-span-5">
                        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
                            <div class="rounded-2xl bg-white/5 p-5 ring-1 ring-white/10">
                                <div class="flex items-start justify-between">
                                    <div>
                                        <p class="text-xs text-slate-400">Weekly deals</p>
                                        <p class="mt-1 text-lg font-semibold">Up to 30% off</p>
                                    </div>
                                    <span class="rounded-xl bg-emerald-400/15 px-3 py-1 text-xs font-semibold text-emerald-200 ring-1 ring-emerald-400/20">Live</span>
                                </div>
                                <p class="mt-3 text-sm text-slate-300">Featured discounts from top-rated sellers.</p>
                            </div>
                            <div class="rounded-2xl bg-white/5 p-5 ring-1 ring-white/10">
                                <p class="text-xs text-slate-400">Seller tools</p>
                                <p class="mt-1 text-lg font-semibold">Orders, inventory, payouts</p>
                                <p class="mt-3 text-sm text-slate-300">Everything you need to launch and scale your store.</p>
                            </div>
                            <div class="rounded-2xl bg-white/5 p-5 ring-1 ring-white/10 sm:col-span-2 lg:col-span-1">
                                <p class="text-xs text-slate-400">Fast checkout</p>
                                <p class="mt-1 text-lg font-semibold">Smooth buyer experience</p>
                                <div class="mt-4 flex flex-wrap gap-2">
                                    <span class="rounded-full bg-white/10 px-3 py-1 text-xs text-slate-200 ring-1 ring-white/10">Secure</span>
                                    <span class="rounded-full bg-white/10 px-3 py-1 text-xs text-slate-200 ring-1 ring-white/10">Mobile-first</span>
                                    <span class="rounded-full bg-white/10 px-3 py-1 text-xs text-slate-200 ring-1 ring-white/10">UX Turbo</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            {# ── Category chips ────────────────────────────────────────────── #}
            {% if categories is not empty %}
                <section id="categories" class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
                    <div class="flex items-end justify-between gap-6 mb-6">
                        <div>
                            <h2 class="text-2xl font-semibold tracking-tight">Shop by category</h2>
                            <p class="mt-2 text-sm text-slate-300">Browse curated collections from our sellers.</p>
                        </div>
                        <a href="{{ path("app_products_browse") }}"
                           class="text-sm font-semibold text-cyan-200 hover:text-cyan-100 no-underline">View all →</a>
                    </div>
                    <div class="grid gap-3 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
                        {% for cat in categories %}
                            <a href="{{ path('app_products_browse', {category: cat.slug}) }}"
                               class="group relative overflow-hidden rounded-2xl bg-white/5 p-5 ring-1 ring-white/10 hover:bg-white/10 hover:ring-white/20 transition-all no-underline">
                                <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/0 to-fuchsia-600/0 group-hover:from-cyan-500/5 group-hover:to-fuchsia-600/5 transition-all duration-300 pointer-events-none rounded-2xl">
                                </div>
                                <div class="relative">
                                    {% if cat.icon %}
                                        <span class="block text-3xl mb-3 leading-none">{{ cat.icon }}</span>
                                    {% else %}
                                        <div class="w-8 h-8 rounded-lg bg-white/10 grid place-items-center mb-3">
                                            <svg class="w-4 h-4 text-slate-400"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="1.5">
                                                <rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" />
                                                <rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" />
                                            </svg>
                                        </div>
                                    {% endif %}
                                    <div class="flex items-start justify-between gap-2">
                                        <div class="min-w-0">
                                            <p class="text-base font-semibold text-slate-100 group-hover:text-white transition-colors truncate">{{ cat.name }}</p>
                                            {% if cat.description %}
                                                <p class="mt-1 text-xs text-slate-400 leading-relaxed line-clamp-2">{{ cat.description }}</p>
                                            {% endif %}
                                        </div>
                                        <svg class="w-4 h-4 text-slate-500 group-hover:text-cyan-300 transition-colors shrink-0 mt-0.5"
                                             viewBox="0 0 12 12"
                                             fill="none">
                                            <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                                        </svg>
                                    </div>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                </section>
            {% else %}
                <section id="categories" class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
                    <div class="flex items-end justify-between gap-6 mb-6">
                        <div>
                            <h2 class="text-2xl font-semibold tracking-tight">Shop by category</h2>
                            <p class="mt-2 text-sm text-slate-300">Curated collections to get you started.</p>
                        </div>
                    </div>
                    <div class="grid gap-3 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4">
                        {% for chip in [
                            {name: 'Electronics',   slug: 'electronics',   icon: '💻', desc: 'Gadgets & accessories'},
                            {name: 'Fashion',        slug: 'fashion',        icon: '👕', desc: 'New styles daily'},
                            {name: 'Home & Living',  slug: 'home-living',   icon: '🏠', desc: 'Décor that fits'},
                            {name: 'Handmade',       slug: 'handmade',      icon: '🎨', desc: 'Crafted with care'},
                            ] %}
                            <a href="{{ path('app_products_browse', {category: chip.slug}) }}"
                               class="group rounded-2xl bg-white/5 p-5 ring-1 ring-white/10 hover:bg-white/10 transition no-underline">
                                <span class="block text-3xl mb-3 leading-none">{{ chip.icon }}</span>
                                <p class="text-base font-semibold text-slate-100 group-hover:text-white transition-colors">{{ chip.name }}</p>
                                <p class="mt-1 text-xs text-slate-400">{{ chip.desc }}</p>
                            </a>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}
            {# ── Featured products ─────────────────────────────────────────── #}
            <section id="featured" class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
                <div class="flex items-end justify-between gap-6 mb-6">
                    <div>
                        <h2 class="text-2xl font-semibold tracking-tight">Featured today</h2>
                        <p class="mt-2 text-sm text-slate-300">Hand-picked items from verified stores.</p>
                    </div>
                    <a href="{{ path("app_products_browse") }}"
                       class="text-sm font-semibold text-cyan-200 hover:text-cyan-100 no-underline">Browse all →</a>
                </div>
                {% if featuredProducts is not empty %}
                    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                        {% for product in featuredProducts %}
                            <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 overflow-hidden hover:ring-white/20 transition-all group">
                                {#
                                  FIX 1 — Consistent image sizes without quality loss.
                                  Industry standard: use `aspect-[4/3]` on the wrapper so every card
                                  reserves the exact same proportional space (width × 75%). The <img>
                                  uses `object-cover object-center` to fill that box, cropping edges
                                  symmetrically rather than distorting. No hard-coded `h-44` needed —
                                  the aspect-ratio CSS property does the math at any breakpoint.
                                  `overflow-hidden` on the link clips the scale-up hover animation.
                                #}
                                <a href="{{ path('app_product_detail', {id: product.id}) }}"
                                   class="block relative overflow-hidden aspect-[4/3] w-full">
                                    {% if product.primaryImageUrl %}
                                        <img src="/uploads/products/{{ product.storeName ~ '/' ~ product.primaryImageUrl }}"
                                             alt="{{ product.productName }}"
                                             class="absolute inset-0 w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-300">
                                    {% else %}
                                        <div class="absolute inset-0 bg-white/[0.03] grid place-items-center">
                                            <svg class="w-10 h-10 text-slate-600"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="1">
                                                <rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" />
                                            </svg>
                                        </div>
                                    {% endif %}
                                </a>
                                <div class="p-5">
                                    {% if product.categoryName is defined and product.categoryName %}
                                        <span class="inline-block mb-2 text-[0.65rem] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full bg-cyan-400/10 text-cyan-300">
                                            {{ product.categoryName }}
                                        </span>
                                    {% endif %}
                                    <div class="flex items-start justify-between gap-4">
                                        <div class="min-w-0">
                                            <p class="text-sm font-semibold text-slate-100 truncate">{{ product.productName }}</p>
                                            <p class="mt-1 text-xs text-slate-400">by {{ product.storeName }}</p>
                                        </div>
                                        <p class="text-sm font-semibold text-slate-100 shrink-0">{{ currency_symbol() ~ product.price }}</p>
                                    </div>
                                    <a href="{{ path('app_product_detail', {id: product.id}) }}"
                                       class="mt-4 block w-full rounded-xl bg-white px-4 py-2.5 text-sm font-semibold text-slate-950 hover:bg-slate-200 text-center no-underline transition-colors">
                                        View product
                                    </a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 px-6 py-12 text-center">
                        <p class="text-slate-400">No featured products yet. Check back soon!</p>
                        <a href="{{ path("register_seller") }}"
                           class="inline-block mt-4 rounded-xl bg-cyan-400 px-5 py-2.5 text-sm font-semibold text-slate-950 hover:bg-cyan-300 transition-colors no-underline">
                            Become a seller →
                        </a>
                    </div>
                {% endif %}
            </section>
        </main>
        {% include 'partials/_footer.html.twig' %}
    </div>
{% endblock %}
