{% extends 'base.html.twig' %}
{% block title %}Marketplace — Buy & Sell{% endblock %}
{% block body %}
    <div class="relative overflow-hidden">
        {% include 'partials/_header.html.twig' %}
        {# Hero #}
        <main class="relative z-10">
            <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
                <div class="grid gap-10 py-14 lg:grid-cols-12 lg:items-center lg:py-20">
                    <div class="lg:col-span-7">
                        <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-xs text-slate-200 ring-1 ring-white/10">
                            <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
                            Trusted by independent sellers worldwide
                        </div>
                        <h1 class="mt-5 text-4xl font-semibold tracking-tight sm:text-5xl">
                            Discover unique products from
                            <span class="bg-gradient-to-r from-fuchsia-300 to-cyan-200 bg-clip-text text-transparent">verified sellers</span>
                        </h1>
                        <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">
                            A modern multi-vendor marketplace with fast checkout, secure payments, and seller tools built for growth.
                        </p>
                        {# Search bar (Stimulus-ready) #}
                        <div class="mt-8">
                            <div data-controller="market-search"
                                 class="flex flex-col gap-3 rounded-2xl bg-white/5 p-4 ring-1 ring-white/10 sm:flex-row sm:items-center">
                                <div class="flex-1">
                                    <label class="sr-only" for="q">Search</label>
                                    <input id="q"
                                           name="q"
                                           type="search"
                                           placeholder="Search products, brands, stores…"
                                           data-market-search-target="input"
                                           class="w-full rounded-xl bg-slate-900/70 px-4 py-3 text-sm text-slate-100 placeholder:text-slate-400 ring-1 ring-white/10 focus:outline-none focus:ring-2 focus:ring-cyan-400/60" />
                                </div>
                                <div class="flex gap-2">
                                    <button type="button"
                                            data-action="market-search#submit"
                                            class="rounded-xl bg-cyan-400 px-4 py-3 text-sm font-semibold text-slate-950 hover:bg-cyan-300">
                                        Search
                                    </button>
                                    <a href=""
                                       class="rounded-xl bg-white/10 px-4 py-3 text-sm font-semibold text-white hover:bg-white/15 ring-1 ring-white/10">
                                        Become a seller
                                    </a>
                                </div>
                            </div>
                            <p class="mt-3 text-xs text-slate-400">Tip: try “handmade”, “electronics”, or “home decor”.</p>
                        </div>
                    </div>
                    {# Hero cards #}
                    <div class="lg:col-span-5">
                        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
                            <div class="rounded-2xl bg-white/5 p-5 ring-1 ring-white/10">
                                <div class="flex items-start justify-between">
                                    <div>
                                        <p class="text-xs text-slate-400">Weekly deals</p>
                                        <p class="mt-1 text-lg font-semibold">Up to 30% off</p>
                                    </div>
                                    <span class="rounded-xl bg-emerald-400/15 px-3 py-1 text-xs font-semibold text-emerald-200 ring-1 ring-emerald-400/20">
                                        Live
                                    </span>
                                </div>
                                <p class="mt-3 text-sm text-slate-300">Featured discounts from top-rated sellers.</p>
                            </div>
                            <div class="rounded-2xl bg-white/5 p-5 ring-1 ring-white/10">
                                <p class="text-xs text-slate-400">Seller tools</p>
                                <p class="mt-1 text-lg font-semibold">Orders, inventory, payouts</p>
                                <p class="mt-3 text-sm text-slate-300">Everything you need to launch and scale your store.</p>
                            </div>
                            <div class="rounded-2xl bg-white/5 p-5 ring-1 ring-white/10 sm:col-span-2 lg:col-span-1">
                                <p class="text-xs text-slate-400">Fast checkout</p>
                                <p class="mt-1 text-lg font-semibold">Smooth buyer experience</p>
                                <div class="mt-4 flex flex-wrap gap-2">
                                    <span class="rounded-full bg-white/10 px-3 py-1 text-xs text-slate-200 ring-1 ring-white/10">Secure</span>
                                    <span class="rounded-full bg-white/10 px-3 py-1 text-xs text-slate-200 ring-1 ring-white/10">Mobile-first</span>
                                    <span class="rounded-full bg-white/10 px-3 py-1 text-xs text-slate-200 ring-1 ring-white/10">UX Turbo</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            {# Categories #}
            <section id="categories" class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
                <div class="flex items-end justify-between gap-6">
                    <div>
                        <h2 class="text-2xl font-semibold tracking-tight">Shop by category</h2>
                        <p class="mt-2 text-sm text-slate-300">Curated collections to get you started.</p>
                    </div>
                    <a href="#"
                       class="text-sm font-semibold text-cyan-200 hover:text-cyan-100">View all</a>
                </div>
                <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                    {% set categories = [
                        {
                            "name": "Electronics",
                            "desc": "Gadgets & accessories"
                        },
                        {
                            "name": "Fashion",
                            "desc": "New styles daily"
                        },
                        {
                            "name": "Home & Living",
                            "desc": "Decor that fits"
                        },
                        {
                            "name": "Handmade",
                            "desc": "Crafted with care"
                        }
                    ] %}
                    {% for c in categories %}
                        <a href="#"
                           class="group rounded-2xl bg-white/5 p-5 ring-1 ring-white/10 hover:bg-white/10 transition">
                            <div class="flex items-center justify-between">
                                <p class="text-base font-semibold">{{ c.name }}</p>
                                <span class="text-slate-400 group-hover:text-white">→</span>
                            </div>
                            <p class="mt-2 text-sm text-slate-300">{{ c.desc }}</p>
                        </a>
                    {% endfor %}
                </div>
            </section>
            {# Featured products (placeholder cards) #}
            <section id="featured" class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
                <div class="flex items-end justify-between gap-6">
                    <div>
                        <h2 class="text-2xl font-semibold tracking-tight">Featured today</h2>
                        <p class="mt-2 text-sm text-slate-300">Hand-picked items from verified stores.</p>
                    </div>
                    <a href="#"
                       class="text-sm font-semibold text-cyan-200 hover:text-cyan-100">Browse products</a>
                </div>
                <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                    {% for i in 1..6 %}
                        <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 overflow-hidden">
                            <div class="h-40 bg-gradient-to-br from-white/10 to-white/0"></div>
                            <div class="p-5">
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <p class="text-sm font-semibold">Product {{ i }}</p>
                                        <p class="mt-1 text-xs text-slate-400">by Store {{ i }}</p>
                                    </div>
                                    <p class="text-sm font-semibold text-slate-100">$ {{ 19 + i }}.00</p>
                                </div>
                                <button class="mt-4 w-full rounded-xl bg-white px-4 py-2.5 text-sm font-semibold text-slate-950 hover:bg-slate-200">
                                    Add to cart
                                </button>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </section>
            {% include 'partials/_footer.html.twig' %}
        </main>
    </div>
{% endblock %}
