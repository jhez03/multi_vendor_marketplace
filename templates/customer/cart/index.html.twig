{% extends 'base.html.twig' %}
{% block title %}
    Your Cart
    {% if itemCount > 0 %}({{ itemCount }}){% endif %}
    — Marketplace
{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap"
          rel="stylesheet">
    <style>
        .font-serif { font-family: 'Instrument Serif', serif; }
        body { font-family: 'DM Sans', sans-serif; }
        @keyframes fade-up { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }
        .anim  { animation: fade-up .3s ease both; }
        .d-1{animation-delay:.04s;} .d-2{animation-delay:.08s;} .d-3{animation-delay:.12s;}
    </style>
{% endblock %}
{% block body %}
    <div class="relative overflow-hidden min-h-screen bg-slate-950">
        {% include 'partials/_header.html.twig' %}
        <main class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
            {# Breadcrumb #}
            <nav class="flex items-center gap-1.5 text-[0.75rem] text-slate-400 mb-8">
                <a href="{{ path("home") }}"
                   class="hover:text-white transition-colors no-underline">Home</a>
                <span>/</span>
                <span class="text-slate-200">Cart</span>
            </nav>
            {# Flash messages #}
            {% for msg in app.flashes('success') %}
                <div class="anim mb-4 flex items-center gap-2 px-4 py-3 rounded-xl bg-cyan-400/10 border border-cyan-400/20 text-cyan-300 text-sm">
                    <svg class="w-4 h-4 shrink-0"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="1.8">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                    {{ msg }}
                </div>
            {% endfor %}
            {% for msg in app.flashes('error') %}
                <div class="anim mb-4 flex items-center gap-2 px-4 py-3 rounded-xl bg-red-400/10 border border-red-400/20 text-red-300 text-sm">
                    <svg class="w-4 h-4 shrink-0"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="1.8">
                        <circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" />
                    </svg>
                    {{ msg }}
                </div>
            {% endfor %}
            <div class="anim d-1 mb-6">
                <h1 class="font-serif text-3xl sm:text-4xl tracking-tight">Your cart</h1>
                <p class="mt-1 text-sm text-slate-400">
                    {{ itemCount }} item{{ itemCount != 1 ? 's' : '' }}
                    {% if itemCount > 0 %}
                        · <a href="{{ path("app_cart_clear") }}"
    class="text-slate-500 hover:text-red-400 transition-colors no-underline"
    onclick="return confirm('Clear entire cart?')"
    data-turbo="false">Clear all</a>
                    {% endif %}
                </p>
            </div>
            {% if cart is empty %}
                {# Empty state #}
                <div class="anim flex flex-col items-center justify-center py-24 text-center">
                    <div class="w-20 h-20 rounded-2xl bg-white/5 ring-1 ring-white/10 grid place-items-center mb-6">
                        <svg class="w-9 h-9 text-slate-500"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.2">
                            <circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" />
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                        </svg>
                    </div>
                    <h2 class="font-serif text-2xl text-slate-100">Your cart is empty</h2>
                    <p class="text-sm text-slate-400 mt-2 max-w-xs">Browse our marketplace and add items you love.</p>
                    <a href="{{ path("app_products_browse") }}"
                       class="mt-6 rounded-xl bg-cyan-400 hover:bg-cyan-300 px-6 py-3 text-sm font-semibold text-slate-950 transition-colors no-underline">
                        Browse products
                    </a>
                </div>
            {% else %}
                <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-8 items-start">
                    {# ── Cart items ── #}
                    <div class="anim d-2 rounded-2xl bg-white/5 ring-1 ring-white/10 overflow-hidden">
                        {% for productId, item in cart %}
                            <div class="flex items-start gap-4 p-5 border-b border-white/[0.07] last:border-b-0 hover:bg-white/[0.03] transition-colors">
                                {# Image #}
                                <div class="w-20 h-20 rounded-xl overflow-hidden bg-white/[0.04] ring-1 ring-white/10 shrink-0">
                                    {% if item.image %}
                                        <img src="/uploads/products/{{ item.shop ~ '/'~ item.image }}"
                                             alt="{{ item.name }}"
                                             class="w-full h-full object-cover">
                                    {% else %}
                                        <div class="w-full h-full grid place-items-center">
                                            <svg class="w-6 h-6 text-slate-600"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="1">
                                                <rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" />
                                                <polyline points="21 15 16 10 5 21" />
                                            </svg>
                                        </div>
                                    {% endif %}
                                </div>
                                {# Details #}
                                <div class="flex-1 min-w-0">
                                    <p class="font-medium text-slate-100 truncate">{{ item.name }}</p>
                                    {% if item.shop %}<p class="text-xs text-slate-500 mt-0.5">{{ item.shop }}</p>{% endif %}
                                    <p class="text-sm font-semibold text-slate-100 mt-1.5">₱{{ (item.price * item.quantity)|number_format(2) }}</p>
                                    <p class="text-xs text-slate-500">₱{{ item.price|number_format(2) }} each</p>
                                </div>
                                {# Qty control + remove #}
                                <div class="flex flex-col items-end gap-3 shrink-0">
                                    {# Quantity form #}
                                    <form method="post"
                                          action="{{ path('app_cart_update', {productId: productId}) }}"
                                          class="flex items-center gap-0 rounded-lg bg-white/[0.06] ring-1 ring-white/10">
                                        <input type="hidden" name="_token" value="{{ csrf_token("cart") }}">
                                        <button type="submit"
                                                name="quantity"
                                                value="{{ max(1, item.quantity - 1) }}"
                                                class="w-8 h-8 grid place-items-center text-slate-400 hover:text-white transition-colors rounded-l-lg hover:bg-white/[0.08] cursor-pointer">
                                            <svg class="w-3 h-3"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="2">
                                                <line x1="5" y1="12" x2="19" y2="12" />
                                            </svg>
                                        </button>
                                        <span class="w-8 text-center text-sm font-medium text-slate-100 select-none">{{ item.quantity }}</span>
                                        <button type="submit"
                                                name="quantity"
                                                value="{{ min(99, item.quantity + 1) }}"
                                                class="w-8 h-8 grid place-items-center text-slate-400 hover:text-white transition-colors rounded-r-lg hover:bg-white/[0.08] cursor-pointer">
                                            <svg class="w-3 h-3"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="2">
                                                <line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" />
                                            </svg>
                                        </button>
                                    </form>
                                    {# Remove #}
                                    <form method="post"
                                          action="{{ path('app_cart_remove', {productId: productId}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token("cart") }}">
                                        <button type="submit"
                                                class="text-[0.7rem] text-slate-500 hover:text-red-400 transition-colors cursor-pointer">
                                            Remove
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    {# ── Order summary ── #}
                    <div class="anim d-3 space-y-4">
                        <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-6">
                            <h2 class="font-serif text-xl text-slate-100 mb-5">Order summary</h2>
                            <div class="space-y-3 text-sm">
                                <div class="flex justify-between text-slate-300">
                                    <span>Subtotal ({{ itemCount }} item{{ itemCount != 1 ? 's' : '' }})</span>
                                    <span>₱{{ subtotal|number_format(2) }}</span>
                                </div>
                                <div class="flex justify-between text-slate-300">
                                    <span>Shipping</span>
                                    <span class="text-cyan-400">Calculated at checkout</span>
                                </div>
                                <div class="border-t border-white/10 pt-3 flex justify-between font-semibold text-slate-100">
                                    <span>Estimated total</span>
                                    <span class="font-serif text-xl">₱{{ subtotal|number_format(2) }}</span>
                                </div>
                            </div>
                            <a href="{{ path("app_checkout_index") }}"
                               class="mt-6 flex items-center justify-center gap-2 w-full rounded-xl bg-cyan-400 hover:bg-cyan-300 px-5 py-3.5 text-sm font-semibold text-slate-950 transition-colors no-underline">
                                Proceed to checkout
                                <svg class="w-3.5 h-3.5" viewBox="0 0 12 12" fill="none">
                                    <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </a>
                            {% if not app.user %}
                                <p class="text-xs text-slate-500 text-center mt-3">
                                    <a href="{{ path("app_login") }}"
                                       class="text-cyan-400 hover:text-cyan-300 no-underline">Sign in</a>
                                    to save your cart and track orders
                                </p>
                            {% endif %}
                        </div>
                        {# Continue shopping #}
                        <a href="{{ path("app_products_browse") }}"
                           class="flex items-center justify-center gap-2 w-full rounded-xl bg-white/[0.04] hover:bg-white/[0.08] ring-1 ring-white/[0.08] px-5 py-3 text-sm text-slate-300 hover:text-white transition-colors no-underline">
                            <svg class="w-3.5 h-3.5"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="1.8">
                                <path d="M19 12H5M12 19l-7-7 7-7" />
                            </svg>
                            Continue shopping
                        </a>
                        {# Trust signals #}
                        <div class="rounded-2xl bg-white/[0.03] ring-1 ring-white/[0.06] p-4 space-y-2.5">
                            {% for signal in [
                                {icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />', text: 'Secure SSL checkout'},
                                {icon: '<rect x="1" y="4" width="22" height="16" rx="2" /><line x1="1" y1="10" x2="23" y2="10" />', text: 'Stripe & PayPal accepted'},
                                {icon: '<path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z" /><line x1="4" y1="22" x2="4" y2="15" />', text: 'Easy returns & refunds'},
                                ] %}
                                <div class="flex items-center gap-2.5">
                                    <svg class="w-4 h-4 text-cyan-400/60 shrink-0"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="1.5">
                                        {{ signal.icon|raw }}
                                    </svg>
                                    <span class="text-xs text-slate-400">{{ signal.text }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% endif %}
        </main>
        {% include 'partials/_footer.html.twig' %}
    </div>
{% endblock %}
