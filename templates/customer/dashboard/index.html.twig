{% extends 'base.html.twig' %}
{% from 'customer/dashboard/partials/_sidebar.html.twig' import sidebar %}
{% block title %}My Dashboard — Marketplace{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap"
          rel="stylesheet">
    <style>
        .font-serif  { font-family: 'Instrument Serif', serif; }
        body { font-family: 'DM Sans', sans-serif; }
        @keyframes fade-up { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:none; } }
        .anim   { animation: fade-up .35s ease both; }
        .d-1 { animation-delay: .04s; } .d-2 { animation-delay: .08s; }
        .d-3 { animation-delay: .12s; } .d-4 { animation-delay: .16s; }
        .d-5 { animation-delay: .22s; } .d-6 { animation-delay: .28s; }
    </style>
{% endblock %}
{% block body %}
    <div class="flex min-h-screen bg-[#0a0908] text-[#e8e4dc]"
         data-controller="sidebar">
        {# Mobile backdrop #}
        <div data-sidebar-target="overlay"
             data-action="click->sidebar#close"
             class="hidden fixed inset-0 z-20 bg-black/60 lg:hidden"></div>
        {# Sidebar #}
        {{ sidebar(user, profile, 'app_dashboard', 'customer') }}
        {# ── Main column ── #}
        <div class="flex flex-col flex-1 min-w-0 overflow-x-hidden">
            {# Top bar #}
            <header class="sticky top-0 z-10 flex items-center justify-between px-5 lg:px-8 py-3.5 bg-[#0f0e0b] border-b border-white/[0.07]">
                <div class="flex items-center gap-3">
                    <button data-action="click->sidebar#open"
                            class="lg:hidden grid place-items-center w-8 h-8 rounded-lg bg-white/[0.05] border border-white/[0.07] text-[#9c9790] hover:text-[#e8e4dc] transition-colors cursor-pointer">
                        <svg class="w-4 h-4"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
                        </svg>
                    </button>
                    <div>
                        <h1 class="font-serif text-xl leading-none text-[#e8e4dc]">Dashboard</h1>
                        <p class="text-[0.72rem] text-[#6b6760] mt-0.5">{{ "now"|date("l, F j, Y") }}</p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <button class="grid place-items-center w-8 h-8 rounded-lg bg-white/[0.05] border border-white/[0.07] text-[#9c9790] hover:text-[#e8e4dc] transition-colors cursor-pointer">
                        <svg class="w-3.5 h-3.5"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
                        </svg>
                    </button>
                    <div class="w-8 h-8 rounded-full grid place-items-center text-[0.7rem] font-semibold text-[#0a0908]"
                         style="background:linear-gradient(135deg,#d4860a,#1a9e87)">{{ user.email|first|upper }}</div>
                </div>
            </header>
            {# Content #}
            <turbo-frame id="customer-main" class="flex-1">
            <main class="p-5 lg:p-8 space-y-6">
                {# ── Greeting ── #}
                <div class="anim relative overflow-hidden rounded-xl bg-[#141210] border border-white/[0.07] px-6 py-5 flex flex-wrap items-center justify-between gap-4"
                     style="background-image:linear-gradient(100deg,rgba(212,134,10,.06) 0%,transparent 55%)">
                    <div>
                        <h2 class="font-serif text-[1.4rem] text-[#e8e4dc] leading-snug">
                            Good to see you, <em class="italic text-[#f0a832]">{{ profile ? profile.fullName|split(" ") |first : 'there' }}</em> 👋
                        </h2>
                        <p class="text-[0.82rem] text-[#6b6760] mt-1">
                            {{ totalOrders }} order{{ totalOrders != 1 ? 's' : '' }} total · member since {{ user.createdAt ? user.createdAt|date("M Y") : 'today' }}
                        </p>
                    </div>
                    <a href="{{ path("app_products_browse") }}"
                       target="_blank"
                       class="inline-flex items-center gap-1.5 shrink-0 bg-[#d4860a] hover:bg-[#f0a832] text-[#0a0908] text-[0.78rem] font-medium px-4 py-2.5 rounded-lg transition-colors no-underline">
                        Shop now
                        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                            <path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </a>
                </div>
                {# ── Stats ── #}
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                    {% for i, s in [
                        { label:'Total orders',  value: totalOrders,    sub:'Lifetime purchases', color:'#d4860a', icon:'<path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 0 1-8 0" />' },
                        { label:'Completed',     value: completedCount, sub:'Delivered orders',   color:'#1a9e87', icon:'<polyline points="20 6 9 17 4 12" />' },
                        { label:'In transit',    value: inTransitCount, sub:'Arriving soon',      color:'#3b8bd4', icon:'<rect x="1" y="3" width="15" height="13" /><polygon points="16 8 20 8 23 11 23 16 16 16 16 8" /><circle cx="5.5" cy="18.5" r="2.5" /><circle cx="18.5" cy="18.5" r="2.5" />' },
                        { label:'Cart items',    value: cart_count,     sub:'Ready to checkout',  color:'#e05c4b', icon:'<circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" /><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />' },
                        ] %}
                        <div class="d-{{ i + 1 }} anim relative overflow-hidden rounded-xl bg-[#141210] border border-white/[0.07] p-4 lg:p-5">
                            <div class="absolute inset-x-0 top-0 h-0.5 rounded-t-xl"
                                 style="background:{{ s.color }}"></div>
                            <div class="flex items-start justify-between gap-2 mb-3">
                                <p class="text-[0.63rem] font-semibold tracking-[0.1em] uppercase text-[#6b6760]">{{ s.label }}</p>
                                <div class="w-7 h-7 rounded-lg grid place-items-center shrink-0"
                                     style="background:{{ s.color }}1a">
                                    <svg class="w-3.5 h-3.5"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="{{ s.color }}"
                                         stroke-width="1.7">
                                        {{ s.icon|raw }}
                                    </svg>
                                </div>
                            </div>
                            <p class="font-serif text-[2rem] leading-none text-[#e8e4dc]">{{ s.value }}</p>
                            <p class="text-[0.7rem] text-[#6b6760] mt-1.5">{{ s.sub }}</p>
                        </div>
                    {% endfor %}
                </div>
                {# ── Two column ── #}
                <div class="grid grid-cols-1 xl:grid-cols-[1fr_340px] gap-6">
                    {# Orders table #}
                    <div class="anim d-5 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                        <div class="flex items-center justify-between px-5 py-3.5 border-b border-white/[0.07]">
                            <h3 class="text-[0.82rem] font-semibold text-[#e8e4dc]">Recent orders</h3>
                            <span class="text-[0.72rem] text-[#6b6760]">{{ totalOrders }} total</span>
                        </div>
                        {% if orders is empty %}
                            {# Empty state — real data, no orders yet #}
                            <div class="flex flex-col items-center justify-center py-12 px-6 text-center">
                                <div class="w-12 h-12 rounded-2xl bg-[#d4860a]/10 grid place-items-center mb-4">
                                    <svg class="w-6 h-6 text-[#d4860a]"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="1.5">
                                        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                        <line x1="3" y1="6" x2="21" y2="6" />
                                        <path d="M16 10a4 4 0 0 1-8 0" />
                                    </svg>
                                </div>
                                <p class="text-[0.88rem] font-medium text-[#e8e4dc]">No orders yet</p>
                                <p class="text-[0.78rem] text-[#6b6760] mt-1 max-w-[220px]">Your purchases will appear here after checkout.</p>
                                <a href="{{ path("app_products_browse") }}"
                                   target="_blank"
                                   class="mt-4 inline-flex items-center gap-1.5 bg-[#d4860a] hover:bg-[#f0a832] text-[#0a0908] text-[0.78rem] font-medium px-4 py-2.5 rounded-lg transition-colors no-underline">
                                    Browse products
                                </a>
                            </div>
                        {% else %}
                            {# Column headers #}
                            <div class="hidden sm:grid grid-cols-[1fr_90px_90px_80px] gap-4 px-5 py-2.5 border-b border-white/[0.07] text-[0.62rem] font-semibold tracking-[0.1em] uppercase text-[#6b6760]">
                                <span>Item</span><span>Date</span><span>Status</span><span class="text-right">Total</span>
                            </div>
                            {% set badge = {
                                "delivered": "bg-[#1a9e87]/15 text-[#22bfa3]",
                                "shipped": "bg-[#3b8bd4]/15 text-[#71b3e8]",
                                "processing": "bg-[#d4860a]/15 text-[#f0a832]",
                                "paid": "bg-[#d4860a]/15 text-[#f0a832]",
                                "pending": "bg-[#b5601e]/15 text-[#e0924a]",
                                "awaiting_payment": "bg-[#b5601e]/15 text-[#e0924a]",
                                "cancelled": "bg-[#e05c4b]/12 text-[#f09080]",
                                "refunded": "bg-white/10 text-[#9c9790]"
                            } %}
                            {# Limit to 6 most recent — already sorted DESC by controller #}
                            {% for order in orders|slice(0, 6) %}
                                <div class="grid grid-cols-[1fr_auto] sm:grid-cols-[1fr_90px_90px_80px] items-center gap-4 px-5 py-3.5 border-b border-white/[0.07] last:border-b-0 hover:bg-[#1a1815] transition-colors">
                                    <div class="flex items-center gap-3 min-w-0">
                                        <div class="w-9 h-9 rounded-lg shrink-0 grid place-items-center text-base bg-[#1a1815] border border-white/[0.07]">
                                            📦
                                        </div>
                                        <div class="min-w-0">
                                            <p class="text-[0.82rem] font-medium text-[#e8e4dc] truncate font-mono">{{ order.orderNumber }}</p>
                                            <p class="text-[0.7rem] text-[#6b6760] mt-0.5">
                                                {{ order.items|length }} item{{ order.items|length != 1 ? 's' : '' }}
                                            </p>
                                        </div>
                                    </div>
                                    <span class="hidden sm:block text-[0.75rem] text-[#6b6760]">{{ order.createdAt|date("M j") }}</span>
                                    <span class="hidden sm:block">
                                        {% set st = order.status.value %}
                                        <span class="text-[0.6rem] font-semibold uppercase tracking-wider px-2 py-1 rounded-full {{ badge[st] ?? 'bg-white/10 text-[#9c9790]' }}">{{ st|replace({"_": " "}) }}</span>
                                    </span>
                                    <div class="text-right">
                                        <p class="text-[0.85rem] font-medium text-[#e8e4dc]">₱{{ order.total|number_format(2) }}</p>
                                        {% set st2 = order.status.value %}
                                        <span class="sm:hidden mt-0.5 inline-block text-[0.6rem] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full {{ badge[st2] ?? 'bg-white/10 text-[#9c9790]' }}">{{ st2|replace({"_": " "}) }}</span>
                                    </div>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    {# Right sidebar #}
                    <div class="anim d-6 space-y-5">
                        {# Account details — real data #}
                        <div class="rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                            <div class="flex items-center justify-between px-5 py-3.5 border-b border-white/[0.07]">
                                <h3 class="text-[0.82rem] font-semibold text-[#e8e4dc]">Account details</h3>
                                <a href="#"
                                   class="text-[0.72rem] text-[#d4860a] hover:opacity-75 transition-opacity no-underline">Edit</a>
                            </div>
                            {% for row in [
                                {label:'Full name', value: profile ? profile.fullName : '—',   icon:'<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" />'},
                                {label:'Email',     value: user.email,                         icon:'<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" />'},
                                {label:'Member since', value: user.createdAt ? user.createdAt|date("F j, Y") : '—', icon:'<rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />'},
                                ] %}
                                <div class="flex items-start gap-3 px-5 py-3.5 border-b border-white/[0.07] last:border-b-0">
                                    <div class="w-7 h-7 rounded-lg shrink-0 grid place-items-center bg-[#1a1815] mt-0.5">
                                        <svg class="w-3.5 h-3.5 text-[#d4860a]"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="1.7">
                                            {{ row.icon|raw }}
                                        </svg>
                                    </div>
                                    <div class="min-w-0">
                                        <p class="text-[0.63rem] font-semibold tracking-[0.08em] uppercase text-[#6b6760]">{{ row.label }}</p>
                                        <p class="text-[0.83rem] text-[#e8e4dc] mt-0.5 break-words">{{ row.value }}</p>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        {# Cart quick-view — only shown when cart has items #}
                        {% if cart_count > 0 %}
                            <div class="rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                                <div class="flex items-center justify-between px-5 py-3.5 border-b border-white/[0.07]">
                                    <h3 class="text-[0.82rem] font-semibold text-[#e8e4dc]">
                                        Cart
                                        <span class="ml-1 inline-flex items-center justify-center w-4 h-4 rounded-full bg-cyan-400 text-[0.55rem] font-bold text-slate-950">{{ cart_count }}</span>
                                    </h3>
                                    <a href="{{ path("app_checkout_index") }}"
                                       target="_blank"
                                       class="text-[0.72rem] text-[#d4860a] hover:opacity-75 no-underline">Checkout →</a>
                                </div>
                                <div class="px-5 py-4 flex items-center justify-between">
                                    <p class="text-[0.82rem] text-[#9c9790]">{{ cart_count }} item{{ cart_count != 1 ? 's' : '' }}</p>
                                    <p class="text-[0.88rem] font-semibold text-[#e8e4dc]">₱{{ cart_subtotal|number_format(2) }}</p>
                                </div>
                                <div class="px-5 pb-4">
                                    <a href="{{ path("app_cart_index") }}"
                                       target="_blank"
                                       class="flex items-center justify-center gap-1.5 w-full rounded-lg bg-cyan-400 hover:bg-cyan-300 text-slate-950 text-[0.78rem] font-semibold py-2.5 transition-colors no-underline">
                                        <svg class="w-3.5 h-3.5"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="2">
                                            <circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" />
                                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                                        </svg>
                                        View cart
                                    </a>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </main>
            </turbo-frame>
        </div>
    </div>
{% endblock %}
