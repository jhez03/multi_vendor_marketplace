{% extends 'base.html.twig' %}
{% block title %}Browse Products — Marketplace{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap"
          rel="stylesheet">
    <style>
        .font-serif { font-family: 'Instrument Serif', serif; }
        body { font-family: 'DM Sans', sans-serif; }
        @keyframes fade-up { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:none; } }
        .anim { animation: fade-up .35s ease both; }
        .product-card:hover .product-img { transform: scale(1.04); }
        .product-img { transition: transform .4s ease; }
    </style>
{% endblock %}
{% block body %}
    <div class="relative overflow-hidden min-h-screen bg-slate-950">
        {% include 'partials/_header.html.twig' %}
        <main class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
            {# Page heading #}
            <div class="anim mb-8">
                <h1 class="font-serif text-3xl sm:text-4xl tracking-tight">Browse products</h1>
                <p class="mt-2 text-sm text-slate-300">{{ products|length }} product{{ products|length != 1 ? 's' : '' }} available</p>
            </div>
            {% if products is empty %}
                <div class="flex flex-col items-center justify-center py-24 text-center">
                    <svg class="w-16 h-16 text-slate-600 mb-5"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="1">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                    </svg>
                    <h2 class="text-xl font-semibold text-slate-200">No products yet</h2>
                    <p class="text-sm text-slate-400 mt-2">Check back soon — sellers are adding new items every day.</p>
                    <a href="{{ path("home") }}"
                       class="mt-6 rounded-xl bg-white px-5 py-2.5 text-sm font-semibold text-slate-950 hover:bg-slate-200 transition-colors no-underline">
                        ← Back to home
                    </a>
                </div>
            {% else %}
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
                    {% for product in products %}
                        {% set imgUrl = product.productImageUrls|first %}
                        {% if imgUrl %}
                            {% set imgUrl = product.shop.storeName ~'/'~imgUrl %}
                        {% endif %}
                        <a href="{{ path('app_product_detail', {id: product.id}) }}"
                           class="product-card group rounded-2xl bg-white/5 ring-1 ring-white/10 overflow-hidden hover:ring-white/20 transition-all no-underline">
                            {# Thumbnail #}
                            <div class="relative aspect-square overflow-hidden bg-white/[0.03]">
                                {% if imgUrl %}
                                    <img class="product-img w-full h-full object-cover"
                                         src="/uploads/products/{{ imgUrl }}"
                                         alt="{{ product.name }}"
                                         loading="lazy">
                                {% else %}
                                    <div class="w-full h-full grid place-items-center">
                                        <svg class="w-10 h-10 text-slate-600"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="1">
                                            <rect x="3" y="3" width="18" height="18" rx="2" />
                                            <circle cx="8.5" cy="8.5" r="1.5" />
                                            <polyline points="21 15 16 10 5 21" />
                                        </svg>
                                    </div>
                                {% endif %}
                            </div>
                            {# Info #}
                            <div class="p-4">
                                {% if product.shop %}
                                    <p class="text-[0.65rem] text-slate-500 mb-1 truncate">{{ product.shop.storeName }}</p>
                                {% endif %}
                                <p class="text-sm font-semibold text-slate-100 truncate leading-snug group-hover:text-white transition-colors">
                                    {{ product.name }}
                                </p>
                                <p class="font-serif text-lg text-slate-100 mt-1.5">₱{{ product.price|number_format(2) }}</p>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </main>
        {% include 'partials/_footer.html.twig' %}
    </div>
{% endblock %}
