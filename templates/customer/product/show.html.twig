{% extends 'base.html.twig' %}
{% block title %}{{ product.name }} — Marketplace{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap"
          rel="stylesheet">
    <style>
        .font-serif { font-family: 'Instrument Serif', serif; }
        body { font-family: 'DM Sans', sans-serif; }
        @keyframes fade-up { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:none; } }
        .anim  { animation: fade-up .35s ease both; }
        .d-1{animation-delay:.04s;}.d-2{animation-delay:.08s;}.d-3{animation-delay:.1s;}.d-4{animation-delay:.14s;}
        .thumb-active { border-color: #22bfa3 !important; }
        .qty-btn:hover { background: rgba(255,255,255,0.08); }
    </style>
{% endblock %}
{% block body %}
    {# ── Header ── #}
    <div class="relative overflow-hidden min-h-screen bg-slate-950">
        {% include 'partials/_header.html.twig' %}
        <main class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
            {# Breadcrumb #}
            <nav class="flex items-center gap-1.5 text-[0.75rem] text-slate-400 mb-8"
                 aria-label="Breadcrumb">
                <a href="{{ path("home") }}"
                   class="hover:text-white transition-colors no-underline">Home</a>
                <span>/</span>
                <a href="{{ path("app_products_browse") }}"
                   class="hover:text-white transition-colors no-underline">Products</a>
                <span>/</span>
                <span class="text-slate-200 truncate max-w-[200px]">{{ product.name }}</span>
            </nav>
            {# Main product grid #}
            <div class="grid grid-cols-1 lg:grid-cols-[1fr_420px] gap-10 items-start">
                {# ── Left: image gallery ── #}
                <div class="anim d-1 space-y-4">
                    {# Primary image #}
                    {% set images = product.productImages %}
                    {% set primaryImg = images|filter(i => i.isPrimary)|first %}
                    {% if primaryImg is not defined and images|length > 0 %}
                        {% set primaryImg = images|first %}
                    {% endif %}
                    <div class="relative rounded-2xl overflow-hidden bg-white/5 ring-1 ring-white/10 aspect-square">
                        {% if primaryImg %}
                            <img id="main-product-img"
                                 src="/uploads/products/{{ product.getShop.getStoreName~'/'~primaryImg.url }}"
                                 alt="{{ product.name }}"
                                 class="w-full h-full object-cover">
                        {% else %}
                            <div class="w-full h-full grid place-items-center bg-white/5">
                                <div class="text-center">
                                    <svg class="w-16 h-16 text-slate-600 mx-auto"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="1">
                                        <rect x="3" y="3" width="18" height="18" rx="2" />
                                        <circle cx="8.5" cy="8.5" r="1.5" />
                                        <polyline points="21 15 16 10 5 21" />
                                    </svg>
                                    <p class="text-sm text-slate-500 mt-3">No image available</p>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                    {# Thumbnail row #}
                    {% if images|length > 1 %}
                        <div class="flex gap-3 overflow-x-auto pb-1">
                            {% for img in images %}
                                <button type="button"
                                        onclick="document.getElementById('main-product-img').src='/uploads/products/{{ product.getShop.storeName ~'/'~img.url }}'; document.querySelectorAll('.product-thumb').forEach(t=>t.classList.remove('thumb-active')); this.querySelector('.product-thumb').classList.add('thumb-active')"
                                        class="shrink-0">
                                    <div class="product-thumb w-20 h-20 rounded-xl overflow-hidden border-2 border-white/10 hover:border-cyan-400/40 transition-colors cursor-pointer {{ loop.first ? 'thumb-active' : '' }}">
                                        <img src="/uploads/products/{{ product.getShop.storeName ~'/'~img.url }}"
                                             alt=""
                                             class="w-full h-full object-cover">
                                    </div>
                                </button>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
                {# ── Right: product info ── #}
                <form id="add-to-cart-form"
                      action="{{ path('app_cart_add', {id: product.id}) }}"
                      method="post">
                    <input type="hidden"
                           name="_token"
                           value="{{ csrf_token('add_to_cart_' ~ product.id) }}">
                    <div class="space-y-6">
                        {# Shop badge #}
                        {% if shop %}
                            <div class="anim d-1 flex items-center gap-2">
                                <div class="w-7 h-7 rounded-lg bg-white/10 grid place-items-center shrink-0">
                                    <svg class="w-3.5 h-3.5 text-slate-300"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="1.8">
                                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                        <polyline points="9 22 9 12 15 12 15 22" />
                                    </svg>
                                </div>
                                <span class="text-sm text-slate-300">{{ shop.storeName }}</span>
                                {% if shop.seller and shop.seller.isVerified %}
                                    <span class="inline-flex items-center gap-1 text-[0.65rem] font-semibold px-2 py-0.5 rounded-full bg-cyan-400/10 text-cyan-300">
                                        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="currentColor">
                                            <path d="M6 0a6 6 0 1 0 0 12A6 6 0 0 0 6 0zm2.77 4.44L5.55 7.95 3.5 5.9a.6.6 0 0 0-.85.85L5.1 9.2a.6.6 0 0 0 .9-.07l3.6-4.8a.6.6 0 0 0-.84-.84z" />
                                        </svg>
                                        Verified
                                    </span>
                                {% endif %}
                            </div>
                        {% endif %}
                        {# Name & price #}
                        <div class="anim d-2">
                            <h1 class="font-serif text-3xl sm:text-4xl tracking-tight text-slate-50 leading-tight">{{ product.name }}</h1>
                            <div class="flex items-baseline gap-3 mt-3">
                                <span class="font-serif text-3xl text-slate-50">₱{{ product.price|number_format(2) }}</span>
                            </div>
                        </div>
                        {# Divider #}
                        <div class="border-t border-white/10"></div>
                        {# Flash messages #}
                        {% for msg in app.flashes('success') %}
                            <div class="anim mb-4 flex items-center gap-2 px-4 py-3 rounded-xl bg-cyan-400/10 border border-cyan-400/20 text-cyan-300 text-sm">
                                <svg class="w-4 h-4 shrink-0"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="1.8">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                {{ msg }}
                            </div>
                        {% endfor %}
                        {# Description #}
                        <div class="anim d-3">
                            <h2 class="text-sm font-semibold text-slate-200 mb-2">Description</h2>
                            <p class="text-sm text-slate-300 leading-relaxed">{{ product.description }}</p>
                        </div>
                        {# Quantity selector #}
                        <div class="anim d-3">
                            <h2 class="text-sm font-semibold text-slate-200 mb-3">Quantity</h2>
                            <div class="flex items-center gap-0 rounded-xl bg-white/5 ring-1 ring-white/10 w-fit">
                                <button type="button"
                                        id="qty-dec"
                                        onclick="const i=document.getElementById('qty-val'); const v=Math.max(1, parseInt(i.textContent)-1); i.textContent=v;"
                                        class="qty-btn w-10 h-10 rounded-l-xl grid place-items-center text-slate-300 hover:text-white transition-colors cursor-pointer">
                                    <svg class="w-3.5 h-3.5"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="2">
                                        <line x1="5" y1="12" x2="19" y2="12" />
                                    </svg>
                                </button>
                                <span id="qty-val"
                                      class="w-10 text-center text-sm font-medium text-slate-100 select-none">1</span>
                                <button type="button"
                                        onclick="const i=document.getElementById('qty-val'); i.textContent=parseInt(i.textContent)+1;"
                                        class="qty-btn w-10 h-10 rounded-r-xl grid place-items-center text-slate-300 hover:text-white transition-colors cursor-pointer">
                                    <svg class="w-3.5 h-3.5"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="2">
                                        <line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                        {# CTA buttons #}
                        <div class="anim d-4 flex flex-col sm:flex-row gap-3">
                            <button type="submit"
                                    class="flex-1 inline-flex items-center justify-center gap-2 rounded-xl bg-cyan-400 hover:bg-cyan-300 px-5 py-3.5 text-sm font-semibold text-slate-950 transition-colors cursor-pointer">
                                <svg class="w-4 h-4"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="2">
                                    <circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" />
                                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                                </svg>
                                Add to cart
                            </button>
                            <button type="button"
                                    class="sm:w-12 inline-flex items-center justify-center rounded-xl bg-white/5 hover:bg-white/10 ring-1 ring-white/10 px-3.5 py-3.5 text-slate-300 hover:text-white transition-colors cursor-pointer"
                                    title="Add to wishlist">
                                <svg class="w-5 h-5"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="1.8">
                                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                                </svg>
                            </button>
                        </div>
                        {# Trust signals #}
                        <div class="anim d-4 grid grid-cols-3 gap-3">
                            {% for signal in [
                                {icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />', label: 'Secure checkout'},
                                {icon: '<path d="M5 12h14M12 5l7 7-7 7" />', label: 'Fast delivery'},
                                {icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" />', label: 'Easy returns'},
                                ] %}
                                <div class="rounded-xl bg-white/[0.03] ring-1 ring-white/[0.07] p-3 text-center">
                                    <svg class="w-5 h-5 text-cyan-400/70 mx-auto mb-1.5"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="1.5">
                                        {{ signal.icon|raw }}
                                    </svg>
                                    <p class="text-[0.65rem] text-slate-400">{{ signal.label }}</p>
                                </div>
                            {% endfor %}
                        </div>
                    </form>
                </div>
            </div>
            {# ── About the store ── #}
            {% if shop %}
                <section class="mt-14 rounded-2xl bg-white/5 ring-1 ring-white/10 p-6 sm:p-8">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-fuchsia-500/15 grid place-items-center shrink-0">
                            <svg class="w-6 h-6 text-fuchsia-300"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="1.5">
                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                <polyline points="9 22 9 12 15 12 15 22" />
                            </svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <h2 class="text-lg font-semibold text-slate-50">{{ shop.storeName }}</h2>
                                {% if shop.seller and shop.seller.isVerified %}
                                    <span class="inline-flex items-center gap-1 text-[0.65rem] font-semibold px-2 py-0.5 rounded-full bg-cyan-400/10 text-cyan-300">
                                        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="currentColor">
                                            <path d="M6 0a6 6 0 1 0 0 12A6 6 0 0 0 6 0zm2.77 4.44L5.55 7.95 3.5 5.9a.6.6 0 0 0-.85.85L5.1 9.2a.6.6 0 0 0 .9-.07l3.6-4.8a.6.6 0 0 0-.84-.84z" />
                                        </svg>
                                        Verified seller
                                    </span>
                                {% endif %}
                            </div>
                            {% if shop.storeDescription %}
                                <p class="text-sm text-slate-300 mt-2 leading-relaxed max-w-2xl">{{ shop.storeDescription }}</p>
                            {% endif %}
                        </div>
                    </div>
                </section>
            {% endif %}
            {# ── Login prompt if not authenticated ── #}
            {% if not app.user %}
                <div class="mt-8 rounded-2xl bg-white/5 ring-1 ring-white/10 px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
                    <div>
                        <p class="font-semibold text-slate-100">Sign in to add to cart</p>
                        <p class="text-sm text-slate-400 mt-0.5">Create a free account to shop, track orders, and save favorites.</p>
                    </div>
                    <div class="flex gap-2 shrink-0">
                        <a href="{{ path("app_login") }}"
                           class="rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-200 bg-white/10 hover:bg-white/15 ring-1 ring-white/10 transition-colors no-underline">
                            Login
                        </a>
                        <a href="{{ path("register_customer") }}"
                           class="rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-950 bg-white hover:bg-slate-200 transition-colors no-underline">
                            Sign up free
                        </a>
                    </div>
                </div>
            {% endif %}
        </main>
        {% include 'partials/_footer.html.twig' %}
    </div>
{% endblock %}
