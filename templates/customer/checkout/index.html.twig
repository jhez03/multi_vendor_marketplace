{% extends 'base.html.twig' %}
{% block title %}Checkout — Marketplace{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap"
          rel="stylesheet">
    <style>
        .font-serif { font-family: 'Instrument Serif', serif; }
        body { font-family: 'DM Sans', sans-serif; }
        @keyframes fade-up { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }
        .anim { animation: fade-up .3s ease both; }
        .d-1{animation-delay:.04s;} .d-2{animation-delay:.08s;} .d-3{animation-delay:.12s;}
        .method-card { cursor:pointer; }
        .method-card input[type=radio]:checked ~ .method-label { border-color: rgba(34,191,163,0.6); background: rgba(34,191,163,0.05); }
        .checkout-input {
            width: 100%;
            padding: 0.625rem 0.875rem;
            background: rgba(15,14,11,0.8);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 0.75rem;
            color: #e8e4dc;
            font-size: 0.875rem;
            transition: border-color .15s, box-shadow .15s;
            outline: none;
        }
        .checkout-input:focus { border-color: rgba(34,191,163,0.5); box-shadow: 0 0 0 3px rgba(34,191,163,0.1); }
        .checkout-input::placeholder { color: #4a4844; }
    </style>
{% endblock %}
{% block body %}
    <div class="relative overflow-hidden min-h-screen bg-slate-950">
        {% include 'partials/_header.html.twig' %}
        <main class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
            {# Breadcrumb + steps #}
            <div class="anim d-1 flex items-center gap-2 text-sm mb-8">
                <a href="{{ path("app_cart_index") }}"
                   class="text-slate-400 hover:text-white no-underline transition-colors">Cart</a>
                <svg class="w-3.5 h-3.5 text-slate-600" viewBox="0 0 12 12" fill="none">
                    <path d="M4 2l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                </svg>
                <span class="text-cyan-400 font-medium">Checkout</span>
                <svg class="w-3.5 h-3.5 text-slate-600" viewBox="0 0 12 12" fill="none">
                    <path d="M4 2l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                </svg>
                <span class="text-slate-500">Confirmation</span>
            </div>
            {# Flash messages #}
            {% for msg in app.flashes('error') %}
                <div class="anim mb-4 flex items-center gap-2 px-4 py-3 rounded-xl bg-red-400/10 border border-red-400/20 text-red-300 text-sm">
                    <svg class="w-4 h-4 shrink-0"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="1.8">
                        <circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" />
                    </svg>
                    {{ msg }}
                </div>
            {% endfor %}
            <h1 class="anim font-serif text-3xl sm:text-4xl tracking-tight mb-8">Checkout</h1>
            <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-8 items-start">
                {# ── Left: address + payment method ── #}
                <div class="anim d-2 space-y-6">
                    {# Delivery address card #}
                    <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-6">
                        <h2 class="font-serif text-xl text-slate-100 mb-5">Delivery address</h2>
                        <form id="checkout-form" class="space-y-4">
                            <input type="hidden" name="_token" value="{{ csrf_token("checkout") }}">
                            <input type="hidden" name="provider" id="provider-field" value="stripe">
                            <div>
                                <label class="block text-xs font-semibold tracking-widest uppercase text-slate-500 mb-1.5">
                                    Full name <span class="text-red-400">*</span>
                                </label>
                                <input type="text"
                                       name="full_name"
                                       class="checkout-input"
                                       placeholder="Juan dela Cruz"
                                       required
                                       value="{{ app.user ? app.user.customerProfile.fullName ?? '' : '' }}">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold tracking-widest uppercase text-slate-500 mb-1.5">Phone number</label>
                                <input type="tel"
                                       name="phone"
                                       class="checkout-input"
                                       placeholder="+63 9XX XXX XXXX">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold tracking-widest uppercase text-slate-500 mb-1.5">
                                    Address <span class="text-red-400">*</span>
                                </label>
                                <input type="text"
                                       name="address_line"
                                       class="checkout-input"
                                       placeholder="House/Unit no., Street name"
                                       required>
                            </div>
                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-xs font-semibold tracking-widest uppercase text-slate-500 mb-1.5">
                                        City <span class="text-red-400">*</span>
                                    </label>
                                    <input type="text"
                                           name="city"
                                           class="checkout-input"
                                           placeholder="Quezon City"
                                           required>
                                </div>
                                <div>
                                    <label class="block text-xs font-semibold tracking-widest uppercase text-slate-500 mb-1.5">
                                        Province <span class="text-red-400">*</span>
                                    </label>
                                    <input type="text"
                                           name="province"
                                           class="checkout-input"
                                           placeholder="Metro Manila"
                                           required>
                                </div>
                            </div>
                            <div class="grid grid-cols-2 gap-3">
                                <div>
                                    <label class="block text-xs font-semibold tracking-widest uppercase text-slate-500 mb-1.5">
                                        Postal code <span class="text-red-400">*</span>
                                    </label>
                                    <input type="text"
                                           name="postal_code"
                                           class="checkout-input"
                                           placeholder="1100"
                                           required>
                                </div>
                            </div>
                        </form>
                    </div>
                    {# Payment method card #}
                    <div class="anim d-3 rounded-2xl bg-white/5 ring-1 ring-white/10 p-6">
                        <h2 class="font-serif text-xl text-slate-100 mb-5">Payment method</h2>
                        <div class="space-y-3">
                            {# Stripe card #}
                            <label class="method-card block">
                                <input type="radio"
                                       name="payment_method_ui"
                                       value="stripe"
                                       class="sr-only"
                                       checked>
                                <div class="method-label rounded-xl border border-cyan-400/60 bg-cyan-400/5 p-4 transition-all">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-3">
                                            <div class="w-9 h-9 rounded-lg bg-[#635bff] grid place-items-center shrink-0">
                                                <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor">
                                                    <path d="M13.976 9.15c-2.172-.806-3.356-1.426-3.356-2.409 0-.831.683-1.305 1.901-1.305 2.227 0 4.515.858 6.09 1.631l.89-5.494C18.252.975 15.697 0 12.165 0 9.667 0 7.589.654 6.104 1.872 4.56 3.147 3.757 4.992 3.757 7.218c0 4.039 2.467 5.76 6.476 7.219 2.585.92 3.445 1.574 3.445 2.583 0 .98-.84 1.545-2.354 1.545-1.875 0-4.965-.921-6.99-2.109l-.9 5.555C5.175 22.99 8.385 24 11.714 24c2.641 0 4.843-.624 6.328-1.813 1.664-1.305 2.525-3.236 2.525-5.732 0-4.128-2.524-5.851-6.591-7.305z" />
                                                </svg>
                                            </div>
                                            <div>
                                                <p class="text-sm font-semibold text-slate-100">Credit / Debit card</p>
                                                <p class="text-xs text-slate-400">Powered by Stripe · Visa, Mastercard, etc.</p>
                                            </div>
                                        </div>
                                        <span class="w-4 h-4 rounded-full border-2 border-cyan-400 bg-cyan-400/30 shrink-0"></span>
                                    </div>
                                    {# Stripe Elements mount point #}
                                    <div id="stripe-element-wrap"
                                         class="mt-4 pt-4 border-t border-white/[0.07]">
                                        <div id="stripe-card-element"
                                             class="rounded-lg bg-[#0f0e0b] border border-white/10 px-4 py-3 min-h-[42px]">
                                        </div>
                                        <div id="stripe-card-errors" class="mt-2 text-xs text-red-400 hidden"></div>
                                    </div>
                                </div>
                            </label>
                            {# PayPal card #}
                            <label class="method-card block">
                                <input type="radio" name="payment_method_ui" value="paypal" class="sr-only">
                                <div class="method-label rounded-xl border border-white/10 p-4 transition-all hover:border-white/20">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center gap-3">
                                            <div class="w-9 h-9 rounded-lg bg-[#003087] grid place-items-center shrink-0">
                                                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
                                                    <text y="18" x="1" font-size="16" font-weight="bold" fill="#009cde">P</text>
                                                </svg>
                                            </div>
                                            <div>
                                                <p class="text-sm font-semibold text-slate-100">PayPal</p>
                                                <p class="text-xs text-slate-400">Pay with your PayPal balance or linked card</p>
                                            </div>
                                        </div>
                                        <span class="w-4 h-4 rounded-full border-2 border-white/30 shrink-0"></span>
                                    </div>
                                    <div id="paypal-button-wrap"
                                         class="mt-4 pt-4 border-t border-white/[0.07] hidden">
                                        <div id="paypal-button-container"></div>
                                    </div>
                                </div>
                            </label>
                        </div>
                        {# Stripe pay now button #}
                        <button id="stripe-pay-btn"
                                type="button"
                                class="mt-5 w-full flex items-center justify-center gap-2 rounded-xl bg-cyan-400 hover:bg-cyan-300 px-5 py-3.5 text-sm font-semibold text-slate-950 transition-colors cursor-pointer disabled:opacity-50">
                            <svg class="w-4 h-4"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="2">
                                <rect x="1" y="4" width="22" height="16" rx="2" /><line x1="1" y1="10" x2="23" y2="10" />
                            </svg>
                            Pay ₱{{ subtotal|number_format(2) }} with card
                        </button>
                        <p class="mt-3 text-center text-xs text-slate-500">
                            <svg class="w-3 h-3 inline"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                            SSL encrypted · Your card is never stored on our servers
                        </p>
                    </div>
                </div>
                {# ── Right: order summary ── #}
                <div class="anim d-3 rounded-2xl bg-white/5 ring-1 ring-white/10 p-6 sticky top-4">
                    <h2 class="font-serif text-xl text-slate-100 mb-5">Order summary</h2>
                    <div class="space-y-3 mb-5">
                        {% for item in cart %}
                            <div class="flex items-start gap-3">
                                <div class="w-10 h-10 rounded-lg overflow-hidden bg-white/[0.04] ring-1 ring-white/10 shrink-0">
                                    {% if item.image %}
                                        <img src="/uploads/products/{{ item.image }}"
                                             alt="{{ item.name }}"
                                             class="w-full h-full object-cover">
                                    {% else %}
                                        <div class="w-full h-full grid place-items-center">
                                            <svg class="w-4 h-4 text-slate-600"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="1">
                                                <rect x="3" y="3" width="18" height="18" rx="2" />
                                            </svg>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm text-slate-200 truncate">{{ item.name }}</p>
                                    <p class="text-xs text-slate-500 mt-0.5">Qty {{ item.quantity }}</p>
                                </div>
                                <p class="text-sm font-medium text-slate-100 shrink-0">₱{{ (item.price * item.quantity)|number_format(2) }}</p>
                            </div>
                        {% endfor %}
                    </div>
                    <div class="border-t border-white/10 pt-4 space-y-2.5 text-sm">
                        <div class="flex justify-between text-slate-400">
                            <span>Subtotal</span>
                            <span>₱{{ subtotal|number_format(2) }}</span>
                        </div>
                        <div class="flex justify-between text-slate-400">
                            <span>Shipping</span>
                            <span class="text-cyan-400">Free</span>
                        </div>
                        <div class="flex justify-between font-semibold text-slate-100 pt-1">
                            <span>Total</span>
                            <span class="font-serif text-xl">₱{{ subtotal|number_format(2) }}</span>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        {% include 'partials/_footer.html.twig' %}
    </div>
    {#
      FIX 2 — Stripe Elements not mounting on first Turbo page load.

      ROOT CAUSE: When Turbo Drive navigates to this page it fires `turbo:load`
      rather than `DOMContentLoaded`. A bare IIFE at the bottom of the body runs
      synchronously during the initial HTML parse, but on a Turbo-driven visit
      the script block is re-evaluated BEFORE the matching DOM nodes are fully
      ready in Turbo's rendering pipeline. `card.mount('#stripe-card-element')`
      therefore targets a node that exists in the old cached snapshot, not the
      live one, and silently fails.

      FIX STRATEGY:
        1. `data-turbo-eval="false"` — Turbo caches and replays <script> tags on
           every visit by default. This attribute tells Turbo to evaluate the
           script only once (the first real load) and skip re-evaluation on
           cache-restore, preventing the "Stripe already initialized" error.
        2. Listen on `turbo:load` instead of running immediately. Turbo fires
           this event after every navigation (including the first page load),
           guaranteeing the DOM is fully ready and the #stripe-card-element
           container is live.
        3. Mount-guard (`_stripeCardMounted` flag) — if the user somehow gets
           the page rendered twice (e.g. Turbo preview + actual load), we don't
           call `elements.create()` or `card.mount()` a second time, which would
           throw "already mounted" errors.
        4. Listen on `turbo:before-cache` to unmount the card element before
           Turbo snapshots the page, so the snapshot is clean and the element
           can be re-mounted on the next visit.
    #}
<script src="https://js.stripe.com/v3/" data-turbo-eval="false"></script>
<script src="https://www.paypal.com/sdk/js?client-id={{ paypalClientId }}&currency=PHP" data-turbo-eval="false"></script>
<div data-controller="checkout" data-checkout-stripe-key-value="{{ stripePublishKey }}" data-checkout-stripe-action-value="{{ path("app_checkout_stripe") }}" data-checkout-paypal-action-value="{{ path("app_checkout_paypal") }}" data-checkout-subtotal-value="{{ subtotal|number_format(2) }}">
{% endblock %}
