{% extends 'base.html.twig' %}
{% block title %}Stripe Payment — Marketplace{% endblock %}
{% block body %}
    {#
  This page is only rendered server-side when JS is disabled.
  In normal flow the checkout JS intercepts the POST and handles the
  Stripe confirmation in-page without navigating here.

  The hidden fields are also read by the JS fetch + confirmCardPayment flow.
#}
    <div class="min-h-screen bg-slate-950 flex items-center justify-center px-4">
        <div class="w-full max-w-md">
            <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-8">
                <h1 class="text-xl font-semibold text-slate-100 mb-2">Complete your payment</h1>
                <p class="text-sm text-slate-400 mb-6">Order {{ order.orderNumber }} · ₱{{ order.total|number_format(2) }}</p>
                <input type="hidden" id="stripe-client-secret" value="{{ clientSecret }}">
                <input type="hidden"
                       id="stripe-return-url"
                       value="{{ url("app_payment_stripe_return") ~ '?payment_intent=' ~ payment.providerTransactionId }}">
                <div id="card-element"
                     class="rounded-lg bg-[#0f0e0b] border border-white/10 px-4 py-3 mb-3 min-h-[42px]"></div>
                <div id="card-errors" class="text-xs text-red-400 mb-4 hidden"></div>
                <button id="pay-btn"
                        type="button"
                        class="w-full rounded-xl bg-cyan-400 hover:bg-cyan-300 px-5 py-3 text-sm font-semibold text-slate-950 transition-colors">
                    Pay ₱{{ order.total|number_format(2) }}
                </button>
                <a href="{{ path("app_cart_index") }}"
                   class="block text-center text-xs text-slate-500 hover:text-slate-300 mt-3 no-underline transition-colors">
                    Cancel and return to cart
                </a>
            </div>
        </div>
    </div>
    <script src="https://js.stripe.com/v3/"></script>
    <script>
(function () {
    const stripe   = Stripe('{{ publishableKey }}');
    const elements = stripe.elements();
    const card     = elements.create('card', {
        style: {
            base: {
                color: '#e8e4dc',
                fontFamily: '"DM Sans", sans-serif',
                fontSize: '14px',
                '::placeholder': { color: '#4a4844' },
            },
            invalid: { color: '#f09080' },
        },
    });
    card.mount('#card-element');

    document.getElementById('pay-btn').addEventListener('click', async () => {
        const btn = document.getElementById('pay-btn');
        btn.disabled    = true;
        btn.textContent = 'Processing…';

        const { error } = await stripe.confirmCardPayment(
            '{{ clientSecret }}',
            { payment_method: { card } }
        );

        if (error) {
            document.getElementById('card-errors').textContent = error.message;
            document.getElementById('card-errors').classList.remove('hidden');
            btn.disabled    = false;
            btn.textContent = 'Pay ₱{{ order.total|number_format(2) }}';
        } else {
            window.location.href = document.getElementById('stripe-return-url').value;
        }
    });
})();
    </script>
{% endblock %}
