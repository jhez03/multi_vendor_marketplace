{% extends 'base.html.twig' %}
{% from 'customer/dashboard/partials/_sidebar.html.twig' import sidebar %}
{% block title %}My Profile — Marketplace{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap"
          rel="stylesheet">
    <style>
        .font-serif { font-family: 'Instrument Serif', serif; }
        body { font-family: 'DM Sans', sans-serif; }
        @keyframes fade-up { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }
        .anim  { animation: fade-up .3s ease both; }
        .d-1{animation-delay:.04s;} .d-2{animation-delay:.08s;} .d-3{animation-delay:.12s;}

        /* Avatar upload ring animation */
        .avatar-ring { transition: box-shadow .2s ease; }
        .avatar-ring:hover { box-shadow: 0 0 0 3px #d4860a; }

        /* Custom file input styling */
        .file-drop-zone {
            transition: border-color .2s, background .2s;
        }
        .file-drop-zone:hover,
        .file-drop-zone:focus-within {
            border-color: rgba(212,134,10,.5);
            background: rgba(212,134,10,.04);
        }

        /* Input focus ring */
        .profile-input:focus {
            border-color: rgba(212,134,10,.5);
            box-shadow: 0 0 0 3px rgba(212,134,10,.12);
            outline: none;
        }
    </style>
{% endblock %}
{% block body %}
    <div class="flex min-h-screen bg-[#0a0908] text-[#e8e4dc]"
         data-controller="sidebar">
        {# Mobile backdrop #}
        <div data-sidebar-target="overlay"
             data-action="click->sidebar#close"
             class="hidden fixed inset-0 z-20 bg-black/60 lg:hidden"></div>
        {{ sidebar(user, profile, 'customer_profile_edit', 'customer') }}
        <div class="flex flex-col flex-1 min-w-0 overflow-x-hidden">
            {# ── Top bar ── #}
            <header class="sticky top-0 z-10 flex items-center justify-between px-5 lg:px-8 py-3.5 bg-[#0f0e0b] border-b border-white/[0.07]">
                <div class="flex items-center gap-3">
                    <button data-action="click->sidebar#open"
                            class="lg:hidden grid place-items-center w-8 h-8 rounded-lg bg-white/[0.05] border border-white/[0.07] text-[#9c9790] hover:text-[#e8e4dc] transition-colors cursor-pointer">
                        <svg class="w-4 h-4"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
                        </svg>
                    </button>
                    <div>
                        <h1 class="font-serif text-xl leading-none text-[#e8e4dc]">My Profile</h1>
                        <p class="text-[0.72rem] text-[#6b6760] mt-0.5">Manage your personal information</p>
                    </div>
                </div>
            </header>
            {# ── Flash messages ── #}
            <div class="px-5 lg:px-8">
                {% for msg in app.flashes('success') %}
                    <div class="mt-5 flex items-center gap-2 px-4 py-3 rounded-xl bg-[#1a9e87]/10 border border-[#1a9e87]/20 text-[#22bfa3] text-[0.82rem]">
                        <svg class="w-4 h-4 shrink-0"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <polyline points="20 6 9 17 4 12" />
                        </svg>
                        {{ msg }}
                    </div>
                {% endfor %}
                {% for msg in app.flashes('error') %}
                    <div class="mt-5 flex items-center gap-2 px-4 py-3 rounded-xl bg-[#e05c4b]/10 border border-[#e05c4b]/20 text-[#f09080] text-[0.82rem]">
                        <svg class="w-4 h-4 shrink-0"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" />
                        </svg>
                        {{ msg }}
                    </div>
                {% endfor %}
            </div>
            {# ── Main content ── #}
            <main class="p-5 lg:p-8">
                {{ form_start(form, {
                                    attr: {
                                    enctype: 'multipart/form-data',
                                    novalidate: 'novalidate',
                                    class: 'space-y-6'
                                    }
                                    }) }}
                    <div class="grid grid-cols-1 xl:grid-cols-[300px_1fr] gap-6 items-start">
                        {# ── Left: Avatar card ── #}
                        <div class="anim d-1 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                            <div class="px-5 py-3.5 border-b border-white/[0.07]">
                                <h2 class="text-[0.82rem] font-semibold text-[#e8e4dc]">Profile photo</h2>
                            </div>
                            <div class="p-6 flex flex-col items-center text-center"
                                 data-controller="image-preview">
                                {# Current avatar display #}
                                <div class="relative mb-5">
                                    {% if profile.avatarUrl %}
                                        <img id="avatar-preview"
                                             data-image-preview-target="preview"
                                             src="/uploads/avatars/{{ profile.avatarUrl }}"
                                             alt="Your avatar"
                                             class="avatar-ring w-28 h-28 rounded-full object-cover border-2 border-white/10 cursor-pointer">
                                    {% else %}
                                        {# Default avatar — initials-based #}
                                        <div id="avatar-preview-placeholder"
                                             data-image-preview-target="empty"
                                             class="avatar-ring w-28 h-28 rounded-full border-2 border-white/10 grid place-items-center text-2xl font-bold text-[#0a0908] cursor-pointer"
                                             style="background: linear-gradient(135deg, #d4860a, #1a9e87)">
                                            {{ (profile.fullName ?? user.email)|first|upper }}
                                        </div>
                                        <img id="avatar-preview"
                                             data-image-preview-target="preview"
                                             src=""
                                             alt="Your avatar"
                                             class="hidden avatar-ring w-28 h-28 rounded-full object-cover border-2 border-white/10">
                                    {% endif %}
                                    {# Upload badge #}
                                    <label for="{{ form.avatarFile.vars.id }}"
                                           class="absolute -bottom-1 -right-1 w-8 h-8 rounded-full bg-[#d4860a] hover:bg-[#f0a832] grid place-items-center cursor-pointer transition-colors shadow-lg border-2 border-[#0a0908]"
                                           title="Change photo">
                                        <svg class="w-3.5 h-3.5 text-white"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="2">
                                            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                                            <circle cx="12" cy="13" r="4" />
                                        </svg>
                                    </label>
                                </div>
                                {# Hidden file input — triggered by the label above #}
                                {{ form_widget(form.avatarFile, {
                                                                attr: {
                                                                'data-image-preview-target': 'input',
                                                                'data-action': 'change->image-preview#show',
                                                                accept: 'image/jpeg,image/png,image/webp,image/gif',
                                                                class: 'sr-only'
                                                                }
                                                                }) }}
                                {% if form.avatarFile.vars.errors|length %}
                                    <p class="mt-2 text-[0.72rem] text-red-400">{{ form.avatarFile.vars.errors|first.message }}</p>
                                {% endif %}
                                <p class="text-[0.72rem] text-[#6b6760] mt-3 leading-relaxed">
                                    JPG, PNG, or WebP
                                    <br>
                                    Max 2 MB
                                </p>
                                {# Account meta #}
                                <div class="w-full mt-6 pt-5 border-t border-white/[0.07] space-y-2 text-left">
                                    <div>
                                        <p class="text-[0.62rem] font-semibold tracking-[0.08em] uppercase text-[#6b6760]">Email</p>
                                        <p class="text-[0.82rem] text-[#9c9790] mt-0.5 break-all">{{ user.email }}</p>
                                    </div>
                                    <div>
                                        <p class="text-[0.62rem] font-semibold tracking-[0.08em] uppercase text-[#6b6760]">Member since</p>
                                        <p class="text-[0.82rem] text-[#9c9790] mt-0.5">{{ user.createdAt ? user.createdAt|date("F j, Y") : '—' }}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {# ── Right: Form fields ── #}
                        <div class="space-y-5">
                            {# Personal information section #}
                            <div class="anim d-2 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                                <div class="flex items-center gap-2.5 px-5 py-3.5 border-b border-white/[0.07]">
                                    <div class="w-6 h-6 rounded-md bg-[#d4860a]/10 grid place-items-center shrink-0">
                                        <svg class="w-3 h-3 text-[#d4860a]"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="2">
                                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                            <circle cx="12" cy="7" r="4" />
                                        </svg>
                                    </div>
                                    <h2 class="text-[0.82rem] font-semibold text-[#e8e4dc]">Personal information</h2>
                                </div>
                                <div class="p-5 space-y-5">
                                    {# Full name #}
                                    <div>
                                        {{ form_label(form.fullName, null, {
                                                                                label_attr: { class: 'block text-[0.72rem] font-semibold tracking-[0.07em] uppercase text-[#6b6760] mb-1.5' }
                                                                                }) }}
                                        {{ form_widget(form.fullName, {
                                                                                attr: {
                                                                                class: 'profile-input w-full px-3.5 py-2.5 rounded-lg bg-[#0f0e0b] border border-white/[0.1] text-[#e8e4dc] text-[0.88rem] placeholder-[#3a3830] transition-all ' ~ (form.fullName.vars.errors|length ? 'border-red-500/60' : '')
                                        }
                                        }) }}
                                        {% if form.fullName.vars.errors|length %}
                                            <p class="mt-1.5 text-[0.72rem] text-red-400 flex items-center gap-1">
                                                <svg class="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="currentColor">
                                                    <path d="M6 0a6 6 0 1 0 0 12A6 6 0 0 0 6 0zm.75 9H5.25V7.5h1.5V9zm0-3H5.25V3h1.5v3z" />
                                                </svg>
                                                {{ form.fullName.vars.errors|first.message }}
                                            </p>
                                        {% endif %}
                                    </div>
                                    {# Email (read-only) #}
                                    <div>
                                        <p class="block text-[0.72rem] font-semibold tracking-[0.07em] uppercase text-[#6b6760] mb-1.5">Email address</p>
                                        <div class="flex items-center gap-2 px-3.5 py-2.5 rounded-lg bg-[#0f0e0b]/50 border border-white/[0.06]">
                                            <svg class="w-3.5 h-3.5 text-[#4a4844] shrink-0"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="1.7">
                                                <rect x="3" y="11" width="18" height="11" rx="2" />
                                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                            </svg>
                                            <p class="text-[0.85rem] text-[#6b6760]">{{ user.email }}</p>
                                        </div>
                                        <p class="mt-1 text-[0.68rem] text-[#4a4844]">Email cannot be changed here. Contact support if needed.</p>
                                    </div>
                                    {# Birth date #}
                                    <div>
                                        {{ form_label(form.birthDate, null, {
                                                                                label_attr: { class: 'block text-[0.72rem] font-semibold tracking-[0.07em] uppercase text-[#6b6760] mb-1.5' }
                                                                                }) }}
                                        {{ form_widget(form.birthDate, {
                                                                                attr: {
                                                                                class: 'profile-input w-full px-3.5 py-2.5 rounded-lg bg-[#0f0e0b] border border-white/[0.1] text-[#e8e4dc] text-[0.88rem] transition-all ' ~ (form.birthDate.vars.errors|length ? 'border-red-500/60' : '')
                                        }
                                        }) }}
                                        {% if form.birthDate.vars.errors|length %}
                                            <p class="mt-1.5 text-[0.72rem] text-red-400 flex items-center gap-1">
                                                <svg class="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="currentColor">
                                                    <path d="M6 0a6 6 0 1 0 0 12A6 6 0 0 0 6 0zm.75 9H5.25V7.5h1.5V9zm0-3H5.25V3h1.5v3z" />
                                                </svg>
                                                {{ form.birthDate.vars.errors|first.message }}
                                            </p>
                                        {% endif %}
                                        <p class="mt-1 text-[0.68rem] text-[#4a4844]">Optional. Used to personalise your experience.</p>
                                    </div>
                                </div>
                            </div>
                            {# Account security section (read-only info) #}
                            <div class="anim d-3 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                                <div class="flex items-center gap-2.5 px-5 py-3.5 border-b border-white/[0.07]">
                                    <div class="w-6 h-6 rounded-md bg-[#3b8bd4]/10 grid place-items-center shrink-0">
                                        <svg class="w-3 h-3 text-[#3b8bd4]"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="2">
                                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                        </svg>
                                    </div>
                                    <h2 class="text-[0.82rem] font-semibold text-[#e8e4dc]">Account security</h2>
                                </div>
                                <div class="p-5">
                                    <div class="flex items-center justify-between py-3 border-b border-white/[0.07]">
                                        <div>
                                            <p class="text-[0.82rem] text-[#e8e4dc]">Password</p>
                                            <p class="text-[0.7rem] text-[#6b6760] mt-0.5">Last changed: unknown</p>
                                        </div>
                                        <span class="text-[0.72rem] text-[#4a4844] px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07]">
                                            Coming soon
                                        </span>
                                    </div>
                                    <div class="flex items-center justify-between py-3">
                                        <div>
                                            <p class="text-[0.82rem] text-[#e8e4dc]">Two-factor authentication</p>
                                            <p class="text-[0.7rem] text-[#6b6760] mt-0.5">Add an extra layer of security</p>
                                        </div>
                                        <span class="text-[0.72rem] text-[#4a4844] px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.07]">
                                            Coming soon
                                        </span>
                                    </div>
                                </div>
                            </div>
                            {# Submit bar #}
                            <div class="anim d-3 flex items-center justify-between gap-4 pt-2">
                                <a href="{{ path("customer_dashboard") }}"
                                   class="px-5 py-2.5 rounded-lg text-[0.82rem] text-[#9c9790] hover:text-[#e8e4dc] transition-colors border border-white/[0.07] hover:border-white/[0.15] no-underline">
                                    Cancel
                                </a>
                                <button type="submit"
                                        class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg text-[0.84rem] font-semibold text-[#0a0908] bg-[#d4860a] hover:bg-[#f0a832] transition-colors cursor-pointer">
                                    <svg class="w-3.5 h-3.5"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="2">
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>
                                    Save changes
                                </button>
                            </div>
                        </div>
                    </div>
                {{ form_end(form) }}
            </main>
        </div>
    </div>
{% endblock %}
