{% extends 'base.html.twig' %}
{% block title %}
    {% if query %}
        "{{ query }}" — Search results · Marketplace
    {% else %}
        Search · Marketplace
    {% endif %}
{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap"
          rel="stylesheet">
    <style>
        .font-serif { font-family: 'Instrument Serif', serif; }
        body         { font-family: 'DM Sans', sans-serif; }

        @keyframes fade-up {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .anim { animation: fade-up .32s ease both; }
        .d-1  { animation-delay: .04s; }
        .d-2  { animation-delay: .08s; }
        .d-3  { animation-delay: .14s; }

        /* Card hover lift */
        .product-card { transition: transform .2s ease, box-shadow .2s ease; }
        .product-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 32px rgba(0,0,0,.45);
        }
        .product-img  { transition: transform .4s ease; }
        .product-card:hover .product-img { transform: scale(1.05); }

        /* Highlighted match text */
        mark {
            background: rgba(212,134,10,.22);
            color: #f0a832;
            border-radius: 2px;
            padding: 0 2px;
        }

        /* Spinner */
        @keyframes spin { to { transform: rotate(360deg); } }
        .spinner { animation: spin .7s linear infinite; }
    </style>
{% endblock %}
{% block body %}
    <div class="relative overflow-hidden min-h-screen bg-slate-950">
        {# ── Ambient glow ── #}
        <div class="pointer-events-none absolute inset-0 overflow-hidden">
            <div class="absolute -top-32 left-1/3 h-[500px] w-[500px] rounded-full bg-amber-600/10 blur-3xl"></div>
            <div class="absolute top-64 right-[-80px] h-[360px] w-[360px] rounded-full bg-cyan-500/10 blur-3xl"></div>
        </div>
        {% include 'partials/_header.html.twig' %}
        <main class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-10 pb-24">
            {# ── Search bar ── #}
            <div class="anim d-1 max-w-2xl mx-auto mb-10"
                 data-controller="market-search"
                 data-market-search-url-value="{{ path("app_search") }}">
                <h1 class="font-serif text-4xl sm:text-5xl text-slate-50 mb-6 text-center tracking-tight">
                    {% if query %}
                        Results for <em class="italic text-amber-400">{{ query|e }}</em>
                    {% else %}
                        Search the marketplace
                    {% endif %}
                </h1>
                <div class="relative flex items-center gap-2 rounded-2xl bg-white/5 p-2 ring-1 ring-white/10 focus-within:ring-amber-500/40 transition-all duration-200">
                    {# Search icon #}
                    <div class="pl-3 shrink-0 text-slate-400">
                        <svg class="w-4 h-4"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2">
                            <circle cx="11" cy="11" r="8" />
                            <path d="m21 21-4.35-4.35" />
                        </svg>
                    </div>
                    {# Input #}
                    <input data-market-search-target="input"
                           data-action="input->market-search#onInput keydown.enter->market-search#submit"
                           type="search"
                           name="q"
                           value="{{ query|e }}"
                           placeholder="Search products, brands, stores…"
                           maxlength="200"
                           autocomplete="off"
                           spellcheck="false"
                           class="flex-1 bg-transparent px-2 py-2.5 text-sm text-slate-100 placeholder:text-slate-500 outline-none"
                           aria-label="Search marketplace">
                    {# Spinner — shown while Turbo is navigating #}
                    <div data-market-search-target="spinner" class="hidden shrink-0 pr-1">
                        <svg class="spinner w-4 h-4 text-amber-400"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2">
                            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                        </svg>
                    </div>
                    {# Clear button #}
                    <button data-market-search-target="clear"
                            data-action="click->market-search#clear"
                            class="{{ query ? '' : 'hidden' }} shrink-0 grid place-items-center w-7 h-7 rounded-lg text-slate-500 hover:text-slate-200 hover:bg-white/10 transition-colors cursor-pointer"
                            title="Clear search"
                            type="button"
                            aria-label="Clear search">
                        <svg class="w-3.5 h-3.5"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2">
                            <path d="M18 6 6 18M6 6l12 12" />
                        </svg>
                    </button>
                    {# Search button #}
                    <button type="button"
                            data-action="click->market-search#submit"
                            class="shrink-0 rounded-xl bg-amber-500 hover:bg-amber-400 text-slate-950 text-sm font-semibold px-4 py-2.5 transition-colors cursor-pointer">
                        Search
                    </button>
                </div>
                {# Query hint #}
                {% if query %}
                    <p class="text-center text-xs text-slate-500 mt-3">
                        Tip: press <kbd class="px-1.5 py-0.5 rounded bg-white/10 text-slate-300 font-mono text-[0.7rem]">Enter</kbd>
                        or keep typing to update results automatically.
                    </p>
                {% endif %}
            </div>
            {# ── Results area ── #}
            {% if not searched %}
                {# ── Empty / landing state ── #}
                <div class="anim d-2 flex flex-col items-center justify-center py-20 text-center">
                    <div class="w-20 h-20 rounded-3xl bg-white/5 ring-1 ring-white/10 grid place-items-center mb-6">
                        <svg class="w-9 h-9 text-slate-500"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.3">
                            <circle cx="11" cy="11" r="8" />
                            <path d="m21 21-4.35-4.35" />
                        </svg>
                    </div>
                    <h2 class="font-serif text-2xl text-slate-200">Discover something new</h2>
                    <p class="text-sm text-slate-500 mt-2 max-w-xs">Type a product name, category, or store name above to get started.</p>
                    {# Suggestion chips #}
                    <div class="flex flex-wrap gap-2 justify-center mt-6">
                        {% for suggestion in ['Electronics', 'Handmade', 'Fashion', 'Home & Living', 'Gadgets'] %}
                            <a href="{{ path('app_search', {q: suggestion}) }}"
                               class="inline-flex items-center gap-1.5 rounded-full bg-white/5 ring-1 ring-white/10 px-4 py-1.5 text-xs text-slate-300 hover:bg-white/10 hover:text-white transition-colors no-underline">
                                {{ suggestion }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% elseif products is empty %}
                {# ── No results ── #}
                <div class="anim d-2 flex flex-col items-center justify-center py-20 text-center">
                    <div class="w-20 h-20 rounded-3xl bg-white/5 ring-1 ring-white/10 grid place-items-center mb-6">
                        <svg class="w-9 h-9 text-slate-600"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.3">
                            <circle cx="11" cy="11" r="8" />
                            <path d="m21 21-4.35-4.35" />
                            <path d="M8 11h6M11 8v6" stroke-linecap="round" />
                        </svg>
                    </div>
                    <h2 class="font-serif text-2xl text-slate-200">No results found</h2>
                    <p class="text-sm text-slate-500 mt-2 max-w-xs">
                        No active products matched <strong class="text-slate-300 font-medium">"{{ query|e }}"</strong>.
                        Try a different term or browse our categories.
                    </p>
                    <div class="flex gap-3 mt-6 flex-wrap justify-center">
                        <a href="{{ path("app_products_browse") }}"
                           class="rounded-xl bg-white px-5 py-2.5 text-sm font-semibold text-slate-950 hover:bg-slate-200 transition-colors no-underline">
                            Browse all products
                        </a>
                        <a href="{{ path("home") }}"
                           class="rounded-xl bg-white/10 ring-1 ring-white/10 px-5 py-2.5 text-sm text-slate-200 hover:bg-white/15 transition-colors no-underline">
                            Back to home
                        </a>
                    </div>
                </div>
            {% else %}
                {# ── Results grid ── #}
                <div class="anim d-2">
                    {# Result count header #}
                    <div class="flex items-baseline justify-between mb-5">
                        <p class="text-sm text-slate-400">
                            <span class="font-semibold text-slate-200">{{ products|length }}</span>
                            result{{ products|length != 1 ? 's' : '' }} for
                            <span class="text-amber-400">"{{ query|e }}"</span>
                        </p>
                        <a href="{{ path("app_products_browse") }}"
                           class="text-xs text-slate-500 hover:text-slate-300 transition-colors no-underline">
                            Browse all →
                        </a>
                    </div>
                    {# Grid #}
                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-5">
                        {% for product in products %}
                            {% set primaryImgs = product.productImages|filter(i => i.isPrimary) %}
                            {% set primaryImg = primaryImgs|first %}
                            {% if primaryImg is not defined or primaryImg is empty %}
                                {% set primaryImg = product.productImages|first %}
                            {% endif %}
                            {% set imgPath = primaryImg is not empty
                                                            ? '/uploads/products/' ~ product.shop.storeName ~ '/' ~ primaryImg.url
                                                        : null %}
                            <a href="{{ path('app_product_detail', {id: product.id}) }}"
                               class="product-card group rounded-2xl bg-white/5 ring-1 ring-white/10 hover:ring-amber-500/30 overflow-hidden no-underline">
                                {# Thumbnail #}
                                <div class="relative aspect-square overflow-hidden bg-white/[0.03]">
                                    {% if imgPath %}
                                        <img class="product-img w-full h-full object-cover"
                                             src="{{ imgPath }}"
                                             alt="{{ product.name }}"
                                             loading="lazy">
                                    {% else %}
                                        <div class="w-full h-full grid place-items-center">
                                            <svg class="w-10 h-10 text-slate-700"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="1">
                                                <rect x="3" y="3" width="18" height="18" rx="2" />
                                                <circle cx="8.5" cy="8.5" r="1.5" />
                                                <polyline points="21 15 16 10 5 21" />
                                            </svg>
                                        </div>
                                    {% endif %}
                                    {# Status badge #}
                                    {% if product.status.value == 'active' %}
                                        <div class="absolute top-2 right-2 w-2 h-2 rounded-full bg-emerald-400 ring-2 ring-slate-900/80"></div>
                                    {% endif %}
                                </div>
                                {# Card body #}
                                <div class="p-3.5">
                                    {% if product.shop %}
                                        <p class="text-[0.65rem] text-slate-500 truncate mb-0.5">{{ product.shop.storeName }}</p>
                                    {% endif %}
                                    <p class="text-sm font-semibold text-slate-100 truncate leading-snug group-hover:text-white transition-colors">
                                        {{ product.name }}
                                    </p>
                                    <p class="font-serif text-lg text-slate-100 mt-1">₱{{ product.price|number_format(2) }}</p>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </main>
        {% include 'partials/_footer.html.twig' %}
    </div>
{% endblock %}
