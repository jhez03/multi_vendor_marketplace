{% extends 'base.html.twig' %}
{% from 'dashboard/partials/_sidebar.html.twig' import sidebar %}
{% block title %}My Products — Marketplace{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap"
          rel="stylesheet">
    <style>
        .font-serif { font-family: 'Instrument Serif', serif; }
        body { font-family: 'DM Sans', sans-serif; }
        @keyframes fade-up { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }
        .anim { animation: fade-up .3s ease both; }
        .d-1{animation-delay:.04s;}.d-2{animation-delay:.08s;}.d-3{animation-delay:.12s;}
    </style>
{% endblock %}
{% block body %}
    <div class="flex min-h-screen bg-[#0a0908] text-[#e8e4dc]"
         data-controller="sidebar">
        <div data-sidebar-target="overlay"
             data-action="click->sidebar#close"
             class="hidden fixed inset-0 z-20 bg-black/60 lg:hidden"></div>
        {{ sidebar(user, profile, 'app_product_index', 'seller') }}
        <div class="flex flex-col flex-1 min-w-0 overflow-x-hidden">
            {# Top bar #}
            <header class="sticky top-0 z-10 flex items-center justify-between px-5 lg:px-8 py-3.5 bg-[#0f0e0b] border-b border-white/[0.07]">
                <div class="flex items-center gap-3">
                    <button data-action="click->sidebar#open"
                            class="lg:hidden grid place-items-center w-8 h-8 rounded-lg bg-white/[0.05] border border-white/[0.07] text-[#9c9790] hover:text-[#e8e4dc] transition-colors cursor-pointer">
                        <svg class="w-4 h-4"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
                        </svg>
                    </button>
                    <div>
                        <h1 class="font-serif text-xl leading-none text-[#e8e4dc]">Products</h1>
                        <p class="text-[0.72rem] text-[#6b6760] mt-0.5">{{ products|length }} listing{{ products|length != 1 ? 's' : '' }}</p>
                    </div>
                </div>
                <a href="{{ path("app_product_new") }}"
                   class="inline-flex items-center gap-1.5 bg-[#b5601e] hover:bg-[#d4860a] text-white text-[0.78rem] font-medium px-3.5 py-2 rounded-lg transition-colors no-underline">
                    <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                        <path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                    Add product
                </a>
            </header>
            {# Flash messages #}
            {% for msg in app.flashes('success') %}
                <div class="mx-5 lg:mx-8 mt-5 flex items-center gap-2 px-4 py-3 rounded-xl bg-[#1a9e87]/10 border border-[#1a9e87]/20 text-[#22bfa3] text-[0.82rem]">
                    <svg class="w-4 h-4 shrink-0"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="1.8">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                    {{ msg }}
                </div>
            {% endfor %}
            <main class="p-5 lg:p-8">
                {% if products is empty %}
                    {# Empty state #}
                    <div class="anim flex flex-col items-center justify-center py-24 text-center">
                        <div class="w-16 h-16 rounded-2xl bg-[#b5601e]/10 grid place-items-center mb-5">
                            <svg class="w-8 h-8 text-[#b5601e]"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="1.5">
                                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                                <polyline points="3.27 6.96 12 12.01 20.73 6.96" /><line x1="12" y1="22.08" x2="12" y2="12" />
                            </svg>
                        </div>
                        <h2 class="font-serif text-2xl text-[#e8e4dc]">No products yet</h2>
                        <p class="text-[0.85rem] text-[#6b6760] mt-2 max-w-xs">
                            Add your first product to start appearing in search results and selling.
                        </p>
                        <a href="{{ path("app_product_new") }}"
                           class="mt-6 inline-flex items-center gap-2 bg-[#b5601e] hover:bg-[#d4860a] text-white text-[0.82rem] font-medium px-5 py-3 rounded-xl transition-colors no-underline">
                            <svg class="w-3.5 h-3.5" viewBox="0 0 12 12" fill="none">
                                <path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                            </svg>
                            Add your first product
                        </a>
                    </div>
                {% else %}
                    {# Stats bar #}
                    {% set activeCount = products|filter(p => p.status.value == 'active')|length %}
                    {% set draftCount = products|filter(p => p.status.value == 'draft')|length %}
                    <div class="anim d-1 grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
                        {% for stat in [
                            {label: 'Total',       value: products|length,  color: '#d4860a'},
                            {label: 'Active',      value: activeCount,       color: '#1a9e87'},
                            {label: 'Drafts',      value: draftCount,        color: '#9c9790'},
                            {label: 'Discontinued',value: products|filter(p => p.status.value == 'Discontinued')|length, color: '#e05c4b'},
                            ] %}
                            <div class="relative overflow-hidden rounded-xl bg-[#141210] border border-white/[0.07] p-4">
                                <div class="absolute inset-x-0 top-0 h-0.5 rounded-t-xl"
                                     style="background:{{ stat.color }}"></div>
                                <p class="text-[0.63rem] font-semibold tracking-[0.1em] uppercase text-[#6b6760]">{{ stat.label }}</p>
                                <p class="font-serif text-2xl leading-none text-[#e8e4dc] mt-1">{{ stat.value }}</p>
                            </div>
                        {% endfor %}
                    </div>
                    {# Product grid #}
                    <div class="anim d-2 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                        {# Table header #}
                        <div class="hidden sm:grid grid-cols-[56px_1fr_120px_100px_80px_80px] gap-4 px-5 py-3 border-b border-white/[0.07] text-[0.62rem] font-semibold tracking-[0.1em] uppercase text-[#6b6760]">
                            <span></span>
                            <span>Product</span>
                            <span>Status</span>
                            <span>Price</span>
                            <span>Listed</span>
                            <span class="text-right">Actions</span>
                        </div>
                        {% for product in products %}
                            {# {% set imgUrl = product.productImageUrls|first ?? null %} #}
                            {% set imgUrl = product.productImageUrls|first %}
                            {% if imgUrl is not empty %}
                                {% set imgUrl = product.shop.storeName ~'/'~imgUrl %}
                            {% else %}
                                {% set imgUrl = null %}
                            {% endif %}
                            <div class="grid grid-cols-[56px_1fr_auto] sm:grid-cols-[56px_1fr_120px_100px_80px_80px] items-center gap-4 px-5 py-4 border-b border-white/[0.07] last:border-b-0 hover:bg-[#1a1815] transition-colors group">
                                {# Thumbnail #}
                                <div class="w-12 h-12 rounded-lg overflow-hidden bg-[#1a1815] border border-white/[0.07] shrink-0">
                                    {% if imgUrl %}
                                        <img src="/uploads/products/{{ imgUrl }}"
                                             alt="{{ product.name }}"
                                             class="w-full h-full object-cover">
                                    {% else %}
                                        <div class="w-full h-full grid place-items-center">
                                            <svg class="w-5 h-5 text-[#3a3830]"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="1.5">
                                                <rect x="3" y="3" width="18" height="18" rx="2" />
                                                <circle cx="8.5" cy="8.5" r="1.5" />
                                                <polyline points="21 15 16 10 5 21" />
                                            </svg>
                                        </div>
                                    {% endif %}
                                </div>
                                {# Name + description #}
                                <div class="min-w-0">
                                    <p class="text-[0.88rem] font-medium text-[#e8e4dc] truncate leading-tight">{{ product.name }}</p>
                                    <p class="text-[0.72rem] text-[#6b6760] mt-0.5 truncate">
                                        {{ product.description|slice(0, 80) }}
                                        {% if product.description|length > 80 %}…{% endif %}
                                    </p>
                                </div>
                                {# Status badge #}
                                <div class="hidden sm:block">
                                    {% if product.status.value == 'active' %}
                                        <span class="inline-flex items-center gap-1 text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full bg-[#1a9e87]/15 text-[#22bfa3]">
                                            <span class="w-1.5 h-1.5 rounded-full bg-[#22bfa3] inline-block"></span>Active
                                        </span>
                                    {% elseif product.status.value == 'draft' %}
                                        <span class="inline-flex items-center gap-1 text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full bg-white/[0.07] text-[#9c9790]">
                                            <span class="w-1.5 h-1.5 rounded-full bg-[#6b6760] inline-block"></span>Draft
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center gap-1 text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full bg-[#e05c4b]/12 text-[#f09080]">
                                            <span class="w-1.5 h-1.5 rounded-full bg-[#e05c4b] inline-block"></span>Discontinued
                                        </span>
                                    {% endif %}
                                </div>
                                {# Price #}
                                <p class="hidden sm:block text-[0.88rem] font-medium text-[#e8e4dc]">₱{{ product.price|number_format(2) }}</p>
                                {# Date #}
                                <p class="hidden sm:block text-[0.75rem] text-[#6b6760]">{{ product.createdAt|date("M j, Y") }}</p>
                                {# Actions #}
                                <div class="flex items-center justify-end gap-1.5">
                                    <a href="{{ path('app_product_show', {id: product.id}) }}"
                                       class="grid place-items-center w-7 h-7 rounded-lg text-[#6b6760] hover:text-[#e8e4dc] hover:bg-white/[0.07] transition-colors"
                                       title="View">
                                        <svg class="w-3.5 h-3.5"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="1.8">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                            <circle cx="12" cy="12" r="3" />
                                        </svg>
                                    </a>
                                    <a href="{{ path('app_product_edit', {id: product.id}) }}"
                                       class="grid place-items-center w-7 h-7 rounded-lg text-[#6b6760] hover:text-[#d4860a] hover:bg-[#d4860a]/[0.08] transition-colors"
                                       title="Edit">
                                        <svg class="w-3.5 h-3.5"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="1.8">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                        </svg>
                                    </a>
                                    <a href="{{ path('app_product_del', {id: product.id}) }}"
                                       class="grid place-items-center w-7 h-7 rounded-lg text-[#6b6760] hover:text-[#d4860a] hover:bg-[#d4860a]/[0.08] transition-colors"
                                       title="Delete">
                                        <svg class="w-3.5 h-3.5"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="1.8"
                                             stroke-linecap="round"
                                             stroke-linejoin="round">
                                            <rect x="3" y="6" width="18" height="14" rx="2" />
                                            <path d="M9 10v6M15 10v6" />
                                            <path d="M8 6V4h8v2" />
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </main>
        </div>
    </div>
{% endblock %}
