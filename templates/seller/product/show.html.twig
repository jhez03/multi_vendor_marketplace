{% extends 'base.html.twig' %}
{% from 'seller/dashboard/partials/_sidebar.html.twig' import sidebar %}
{% block title %}{{ product.name }} — My Products{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap"
          rel="stylesheet">
    <style>
        .font-serif { font-family: 'Instrument Serif', serif; }
        body { font-family: 'DM Sans', sans-serif; }
        @keyframes fade-up { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }
        .anim  { animation: fade-up .3s ease both; }
        .d-1{animation-delay:.04s;}.d-2{animation-delay:.08s;}.d-3{animation-delay:.12s;}
        .thumb-active { border-color: #d4860a !important; }
    </style>
{% endblock %}
{% block body %}
    <div class="flex min-h-screen bg-[#0a0908] text-[#e8e4dc]"
         data-controller="sidebar">
        <div data-sidebar-target="overlay"
             data-action="click->sidebar#close"
             class="hidden fixed inset-0 z-20 bg-black/60 lg:hidden"></div>
        {{ sidebar(user, profile, 'app_product_index', 'seller') }}
        <div class="flex flex-col flex-1 min-w-0 overflow-x-hidden">
            {# Top bar #}
            <header class="sticky top-0 z-10 flex items-center justify-between px-5 lg:px-8 py-3.5 bg-[#0f0e0b] border-b border-white/[0.07]">
                <div class="flex items-center gap-3">
                    <button data-action="click->sidebar#open"
                            class="lg:hidden grid place-items-center w-8 h-8 rounded-lg bg-white/[0.05] border border-white/[0.07] text-[#9c9790] hover:text-[#e8e4dc] transition-colors cursor-pointer">
                        <svg class="w-4 h-4"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
                        </svg>
                    </button>
                    {# Breadcrumb #}
                    <nav class="flex items-center gap-1.5 text-[0.75rem]"
                         aria-label="Breadcrumb">
                        <a href="{{ path("app_dashboard") }}"
                           class="text-[#6b6760] hover:text-[#e8e4dc] transition-colors no-underline">Dashboard</a>
                        <svg class="w-3 h-3 text-[#3a3830]" viewBox="0 0 12 12" fill="none">
                            <path d="M4 2l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                        </svg>
                        <a href="{{ path("app_product_index") }}"
                           class="text-[#6b6760] hover:text-[#e8e4dc] transition-colors no-underline">Products</a>
                        <svg class="w-3 h-3 text-[#3a3830]" viewBox="0 0 12 12" fill="none">
                            <path d="M4 2l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                        </svg>
                        <span class="text-[#e8e4dc] font-medium truncate max-w-[200px]">{{ product.name }}</span>
                    </nav>
                </div>
                <div class="flex items-center gap-2">
                    <a href="{{ path('app_product_edit', {id: product.id}) }}"
                       class="inline-flex items-center gap-1.5 bg-[#b5601e] hover:bg-[#d4860a] text-white text-[0.78rem] font-medium px-3.5 py-2 rounded-lg transition-colors no-underline">
                        <svg class="w-3 h-3"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg>
                        Edit product
                    </a>
                </div>
            </header>
            <main class="p-5 lg:p-8 space-y-6">
                {# Flash #}
                {% for msg in app.flashes('success') %}
                    <div class="flex items-center gap-2 px-4 py-3 rounded-xl bg-[#1a9e87]/10 border border-[#1a9e87]/20 text-[#22bfa3] text-[0.82rem]">
                        <svg class="w-4 h-4 shrink-0"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <polyline points="20 6 9 17 4 12" />
                        </svg>
                        {{ msg }}
                    </div>
                {% endfor %}
                {# Main two-column layout #}
                <div class="grid grid-cols-1 xl:grid-cols-[1fr_340px] gap-6 items-start">
                    {# ── Left column ── #}
                    <div class="space-y-5">
                        {# Image gallery card #}
                        <div class="anim d-1 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                            {% set images = product.productImages %}
                            {% set filtered = images|filter(i => i.isPrimary) %}
                            {% set primaryImg = filtered|first %}
                            {% if primaryImg is not defined or primaryImg is empty %}
                                {% set primaryImg = images|first %}
                            {% endif %}
                            {# Main image #}
                            <div class="relative aspect-video bg-[#0f0e0b] overflow-hidden"
                                 id="main-img-wrap">
                                {% if primaryImg %}
                                    <img id="main-img"
                                         src="/uploads/products/{{ product.getShop.storeName ~'/'~primaryImg.url }}"
                                         alt="{{ product.name }}"
                                         class="w-full h-full object-cover">
                                {% else %}
                                    <div class="w-full h-full grid place-items-center">
                                        <div class="text-center">
                                            <svg class="w-12 h-12 text-[#3a3830] mx-auto"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="1">
                                                <rect x="3" y="3" width="18" height="18" rx="2" />
                                                <circle cx="8.5" cy="8.5" r="1.5" />
                                                <polyline points="21 15 16 10 5 21" />
                                            </svg>
                                            <p class="text-[0.75rem] text-[#4a4844] mt-2">No image uploaded</p>
                                        </div>
                                    </div>
                                {% endif %}
                                {# Status badge overlay #}
                                <div class="absolute top-3 left-3">
                                    {% if product.status.value == 'active' %}
                                        <span class="inline-flex items-center gap-1 text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full bg-[#0a0908]/70 text-[#22bfa3] backdrop-blur-sm">
                                            <span class="w-1.5 h-1.5 rounded-full bg-[#22bfa3] inline-block"></span>Live
                                        </span>
                                    {% elseif product.status.value == 'draft' %}
                                        <span class="inline-flex items-center gap-1 text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full bg-[#0a0908]/70 text-[#9c9790] backdrop-blur-sm">
                                            <span class="w-1.5 h-1.5 rounded-full bg-[#6b6760] inline-block"></span>Draft
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center gap-1 text-[0.65rem] font-semibold uppercase tracking-wider px-2.5 py-1 rounded-full bg-[#0a0908]/70 text-[#f09080] backdrop-blur-sm">
                                            Discontinued
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                            {# Thumbnail strip #}
                            {% if images|length > 1 %}
                                <div class="flex gap-2 p-4 border-t border-white/[0.07] overflow-x-auto">
                                    {% for img in images %}
                                        <button type="button"
                                                onclick="document.getElementById('main-img').src='/uploads/products/{{ product.getShop.storeName ~'/'~ img.url }}'; document.querySelectorAll('.img-thumb').forEach(t=>t.classList.remove('thumb-active')); this.querySelector('img').parentElement.classList.add('thumb-active')"
                                                class="shrink-0">
                                            <div class="img-thumb w-14 h-14 rounded-lg overflow-hidden border-2 border-white/[0.07] hover:border-[#d4860a] transition-colors cursor-pointer {{ loop.first ? 'thumb-active' : '' }}">
                                                <img src="/uploads/products/{{ product.getShop.storeName ~'/'~img.url }}"
                                                     alt=""
                                                     class="w-full h-full object-cover">
                                            </div>
                                        </button>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                        {# Product details card #}
                        <div class="anim d-2 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                            <div class="flex items-center gap-2.5 px-5 py-3.5 border-b border-white/[0.07]">
                                <h2 class="text-[0.82rem] font-semibold text-[#e8e4dc]">Product details</h2>
                            </div>
                            <div class="p-5 space-y-5">
                                <div>
                                    <p class="text-[0.65rem] font-semibold tracking-[0.1em] uppercase text-[#6b6760] mb-1.5">Name</p>
                                    <p class="font-serif text-2xl text-[#e8e4dc] leading-snug">{{ product.name }}</p>
                                </div>
                                <div>
                                    <p class="text-[0.65rem] font-semibold tracking-[0.1em] uppercase text-[#6b6760] mb-1.5">Description</p>
                                    <p class="text-[0.88rem] text-[#9c9790] leading-relaxed">{{ product.description }}</p>
                                </div>
                            </div>
                        </div>
                        {# Placeholder analytics card #}
                        <div class="anim d-3 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                            <div class="flex items-center justify-between px-5 py-3.5 border-b border-white/[0.07]">
                                <h2 class="text-[0.82rem] font-semibold text-[#e8e4dc]">Performance</h2>
                                <span class="text-[0.65rem] text-[#4a4844]">Last 30 days</span>
                            </div>
                            <div class="grid grid-cols-3 divide-x divide-white/[0.07]">
                                {% for stat in [
                                    {label: 'Views',     value: '—'},
                                    {label: 'Add to cart', value: '—'},
                                    {label: 'Sales',     value: '—'},
                                    ] %}
                                    <div class="px-5 py-4 text-center">
                                        <p class="font-serif text-xl text-[#e8e4dc]">{{ stat.value }}</p>
                                        <p class="text-[0.68rem] font-semibold tracking-[0.08em] uppercase text-[#6b6760] mt-1">{{ stat.label }}</p>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                    {# ── Right column ── #}
                    <div class="space-y-5">
                        {# Pricing & status #}
                        <div class="anim d-1 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                            <div class="px-5 py-3.5 border-b border-white/[0.07]">
                                <h2 class="text-[0.82rem] font-semibold text-[#e8e4dc]">Pricing &amp; status</h2>
                            </div>
                            <div class="p-5 space-y-4">
                                <div class="flex items-center justify-between">
                                    <p class="text-[0.75rem] text-[#6b6760]">Base price</p>
                                    <p class="font-serif text-2xl text-[#e8e4dc]">₱{{ product.price|number_format(2) }}</p>
                                </div>
                                <div class="flex items-center justify-between">
                                    <p class="text-[0.75rem] text-[#6b6760]">Status</p>
                                    {% if product.status.value == 'active' %}
                                        <span class="text-[0.72rem] font-semibold px-2.5 py-1 rounded-full bg-[#1a9e87]/15 text-[#22bfa3]">Active</span>
                                    {% elseif product.status.value == 'draft' %}
                                        <span class="text-[0.72rem] font-semibold px-2.5 py-1 rounded-full bg-white/[0.07] text-[#9c9790]">Draft</span>
                                    {% else %}
                                        <span class="text-[0.72rem] font-semibold px-2.5 py-1 rounded-full bg-[#e05c4b]/12 text-[#f09080]">Discontinued</span>
                                    {% endif %}
                                </div>
                                <div class="flex items-center justify-between border-t border-white/[0.07] pt-4">
                                    <p class="text-[0.75rem] text-[#6b6760]">Listed on</p>
                                    <p class="text-[0.82rem] text-[#9c9790]">{{ product.createdAt|date("M j, Y") }}</p>
                                </div>
                            </div>
                            <div class="px-5 py-3.5 border-t border-white/[0.07]">
                                <a href="{{ path('app_product_edit', {id: product.id}) }}"
                                   class="flex items-center justify-center gap-2 w-full px-4 py-2.5 rounded-lg bg-white/[0.05] hover:bg-white/[0.1] border border-white/[0.07] text-[0.82rem] text-[#e8e4dc] transition-colors no-underline">
                                    <svg class="w-3.5 h-3.5"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="1.8">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                    Edit this product
                                </a>
                            </div>
                        </div>
                        {# Store info #}
                        <div class="anim d-2 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                            <div class="px-5 py-3.5 border-b border-white/[0.07]">
                                <h2 class="text-[0.82rem] font-semibold text-[#e8e4dc]">Store</h2>
                            </div>
                            <div class="p-5">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-xl bg-[#b5601e]/20 grid place-items-center shrink-0">
                                        <svg class="w-5 h-5 text-[#b5601e]"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="1.7">
                                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                                            <polyline points="9 22 9 12 15 12 15 22" />
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-[0.88rem] font-medium text-[#e8e4dc]">{{ product.shop.storeName }}</p>
                                        {% if profile and profile.verified %}
                                            <span class="text-[0.65rem] text-[#22bfa3]">Verified seller</span>
                                        {% else %}
                                            <span class="text-[0.65rem] text-[#f0a832]">Pending review</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                        {# Quick actions #}
                        <div class="anim d-3 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                            <div class="px-5 py-3.5 border-b border-white/[0.07]">
                                <h2 class="text-[0.82rem] font-semibold text-[#e8e4dc]">Quick actions</h2>
                            </div>
                            <div class="p-3 space-y-1">
                                <a href="{{ path('app_product_edit', {id: product.id}) }}"
                                   class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-[0.82rem] text-[#9c9790] hover:text-[#e8e4dc] hover:bg-[#1a1815] transition-colors no-underline">
                                    <svg class="w-3.5 h-3.5 shrink-0 opacity-60"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="1.8">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                    Edit product details
                                </a>
                                <a href="{{ path("app_products_browse") }}"
                                   class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-[0.82rem] text-[#9c9790] hover:text-[#e8e4dc] hover:bg-[#1a1815] transition-colors no-underline"
                                   target="_blank">
                                    <svg class="w-3.5 h-3.5 shrink-0 opacity-60"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="1.8">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                        <circle cx="12" cy="12" r="3" />
                                    </svg>
                                    Preview as customer
                                </a>
                                <a href="{{ path("app_product_new") }}"
                                   class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-[0.82rem] text-[#9c9790] hover:text-[#e8e4dc] hover:bg-[#1a1815] transition-colors no-underline">
                                    <svg class="w-3.5 h-3.5 shrink-0 opacity-60"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="1.8">
                                        <line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" />
                                    </svg>
                                    Add another product
                                </a>
                                <a href="{{ path("app_product_index") }}"
                                   class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-[0.82rem] text-[#9c9790] hover:text-[#e8e4dc] hover:bg-[#1a1815] transition-colors no-underline">
                                    <svg class="w-3.5 h-3.5 shrink-0 opacity-60"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="1.8">
                                        <line x1="8" y1="6" x2="21" y2="6" /><line x1="8" y1="12" x2="21" y2="12" />
                                        <line x1="8" y1="18" x2="21" y2="18" />
                                        <line x1="3" y1="6" x2="3.01" y2="6" /><line x1="3" y1="12" x2="3.01" y2="12" />
                                        <line x1="3" y1="18" x2="3.01" y2="18" />
                                    </svg>
                                    Back to all products
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
{% endblock %}
