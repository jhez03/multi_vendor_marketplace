{% extends 'base.html.twig' %}
{% from 'dashboard/partials/_sidebar.html.twig' import sidebar %}
{% block title %}{{ editing is defined ? 'Edit Product' : 'Add New Product' }} — Marketplace{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap"
          rel="stylesheet">
    <style>
        .font-serif { font-family: 'Instrument Serif', serif; }
        body { font-family: 'DM Sans', sans-serif; }
        @keyframes fade-up { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }
        .anim { animation: fade-up .3s ease both; }
        .d-1 { animation-delay:.04s; } .d-2 { animation-delay:.08s; } .d-3 { animation-delay:.12s; }
    </style>
{% endblock %}
{% block body %}
    <div class="flex min-h-screen bg-[#0a0908] text-[#e8e4dc]"
         data-controller="sidebar">
        {# Mobile backdrop #}
        <div data-sidebar-target="overlay"
             data-action="click->sidebar#close"
             class="hidden fixed inset-0 z-20 bg-black/60 lg:hidden"></div>
        {# Sidebar #}
        {{ sidebar(user, profile, 'app_product_new', 'seller') }}
        {# ── Main ── #}
        <div class="flex flex-col flex-1 min-w-0 overflow-x-hidden">
            {# Top bar #}
            <header class="sticky top-0 z-10 flex items-center justify-between px-5 lg:px-8 py-3.5 bg-[#0f0e0b] border-b border-white/[0.07]">
                <div class="flex items-center gap-3">
                    <button data-action="click->sidebar#open"
                            class="lg:hidden grid place-items-center w-8 h-8 rounded-lg bg-white/[0.05] border border-white/[0.07] text-[#9c9790] hover:text-[#e8e4dc] transition-colors cursor-pointer">
                        <svg class="w-4 h-4"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.8">
                            <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
                        </svg>
                    </button>
                    {# Breadcrumb #}
                    <nav class="flex items-center gap-1.5 text-[0.75rem]"
                         aria-label="Breadcrumb">
                        <a href="{{ path("app_dashboard") }}"
                           class="text-[#6b6760] hover:text-[#e8e4dc] transition-colors no-underline">Dashboard</a>
                        <svg class="w-3 h-3 text-[#3a3830]" viewBox="0 0 12 12" fill="none">
                            <path d="M4 2l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <a href=""
                           class="text-[#6b6760] hover:text-[#e8e4dc] transition-colors no-underline">Products</a>
                        <svg class="w-3 h-3 text-[#3a3830]" viewBox="0 0 12 12" fill="none">
                            <path d="M4 2l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <span class="text-[#e8e4dc] font-medium">{{ editing is defined ? 'Edit product' : 'New product' }}</span>
                    </nav>
                </div>
                <div class="flex items-center gap-2">
                    <a href=""
                       class="text-[0.75rem] text-[#9c9790] hover:text-[#e8e4dc] transition-colors no-underline">
                        Cancel
                    </a>
                </div>
            </header>
            {# Flash messages #}
            {% for msg in app.flashes('success') %}
                <div class="mx-5 lg:mx-8 mt-5 flex items-center gap-2 px-4 py-3 rounded-xl bg-[#1a9e87]/10 border border-[#1a9e87]/20 text-[#22bfa3] text-[0.82rem]"
                     data-turbo-temporary>
                    <svg class="w-4 h-4 shrink-0"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="1.8">
                        <polyline points="20 6 9 17 4 12" />
                    </svg>
                    {{ msg }}
                </div>
            {% endfor %}
            {% for msg in app.flashes('error') %}
                <div class="mx-5 lg:mx-8 mt-5 flex items-center gap-2 px-4 py-3 rounded-xl bg-[#e05c4b]/10 border border-[#e05c4b]/20 text-[#f09080] text-[0.82rem]"
                     data-turbo-temporary>
                    <svg class="w-4 h-4 shrink-0"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="1.8">
                        <circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" />
                    </svg>
                    {{ msg }}
                </div>
            {% endfor %}
            {# ── Form ── #}
            {{ form_start(form, {
                            attr: {
                            novalidate: 'novalidate',
                            enctype: 'multipart/form-data',
                            class: 'flex-1'
                            }
                            }) }}
                <main class="p-5 lg:p-8">
                    {# Page title #}
                    <div class="anim mb-6">
                        <h1 class="font-serif text-2xl text-[#e8e4dc] leading-none">
                            {{ editing is defined ? 'Edit product' : 'Add new product' }}
                        </h1>
                        <p class="text-[0.78rem] text-[#6b6760] mt-1">
                            {{ editing is defined ? 'Update the details below and save.' : 'Fill in the details below to list a new product in your store.' }}
                        </p>
                    </div>
                    {# Two-column layout: form fields left, image + tips right #}
                    <div class="grid grid-cols-1 xl:grid-cols-[1fr_320px] gap-6 items-start">
                        {# ── Left: form sections ── #}
                        <div class="space-y-5">
                            {# ── Section: Basic info ── #}
                            <section class="anim d-1 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                                <div class="flex items-center gap-2.5 px-5 py-3.5 border-b border-white/[0.07]">
                                    <div class="w-6 h-6 rounded-md bg-[#d4860a]/10 grid place-items-center shrink-0">
                                        <svg class="w-3 h-3 text-[#d4860a]"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="2">
                                            <line x1="8" y1="6" x2="21" y2="6" /><line x1="8" y1="12" x2="21" y2="12" /><line x1="8" y1="18" x2="21" y2="18" /><line x1="3" y1="6" x2="3.01" y2="6" /><line x1="3" y1="12" x2="3.01" y2="12" /><line x1="3" y1="18" x2="3.01" y2="18" />
                                        </svg>
                                    </div>
                                    <h2 class="text-[0.82rem] font-semibold text-[#e8e4dc]">Basic information</h2>
                                </div>
                                <div class="p-5 space-y-5">
                                    {# Product name #}
                                    <div>
                                        {{ form_label(form.name, null, {label_attr: {class: 'block text-[0.72rem] font-semibold tracking-[0.07em] uppercase text-[#6b6760] mb-1.5' }}) }}
                                        {{ form_widget(form.name, {attr: {
                                                                                class: 'w-full px-3.5 py-2.5 rounded-lg bg-[#0f0e0b] border border-white/[0.1] text-[#e8e4dc] text-[0.88rem] placeholder-[#3a3830] outline-none transition-all focus:border-[#d4860a] focus:ring-2 focus:ring-[#d4860a]/15 ' ~ (form.name.vars.errors|length ? 'border-red-500/60' : '')
                                        }}) }}
                                        {% if form.name.vars.errors|length %}
                                            <p class="mt-1.5 text-[0.75rem] text-red-400 flex items-center gap-1">
                                                <svg class="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="currentColor">
                                                    <path d="M6 0a6 6 0 1 0 0 12A6 6 0 0 0 6 0zm.75 9H5.25V7.5h1.5V9zm0-3H5.25V3h1.5v3z" />
                                                </svg>
                                                {{ form.name.vars.errors|first.message }}
                                            </p>
                                        {% endif %}
                                        <p class="mt-1 text-[0.7rem] text-[#4a4844]">Use a clear, descriptive name buyers would search for.</p>
                                    </div>
                                    {# Description #}
                                    <div data-controller="char-counter" data-char-counter-max-value="5000">
                                        <div class="flex items-baseline justify-between mb-1.5">
                                            {{ form_label(form.description, null, {label_attr: {class: 'block text-[0.72rem] font-semibold tracking-[0.07em] uppercase text-[#6b6760]' }}) }}
                                            <span class="text-[0.68rem] text-[#4a4844]">
                                                <span data-char-counter-target="count"></span> / 5000
                                            </span>
                                        </div>
                                        {{ form_widget(form.description, {attr: {
                                                                                'data-char-counter-target': 'input',
                                                                                'data-action': 'input->char-counter#update',
                                                                                maxlength: 5000,
                                                                                class: 'w-full px-3.5 py-2.5 rounded-lg bg-[#0f0e0b] border border-white/[0.1] text-[#e8e4dc] text-[0.88rem] placeholder-[#3a3830] outline-none transition-all resize-y min-h-[120px] focus:border-[#d4860a] focus:ring-2 focus:ring-[#d4860a]/15 ' ~ (form.description.vars.errors|length ? 'border-red-500/60' : '')
                                        }}) }}
                                        {% if form.description.vars.errors|length %}
                                            <p class="mt-1.5 text-[0.75rem] text-red-400 flex items-center gap-1">
                                                <svg class="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="currentColor">
                                                    <path d="M6 0a6 6 0 1 0 0 12A6 6 0 0 0 6 0zm.75 9H5.25V7.5h1.5V9zm0-3H5.25V3h1.5v3z" />
                                                </svg>
                                                {{ form.description.vars.errors|first.message }}
                                            </p>
                                        {% endif %}
                                    </div>
                                    {# Category #}
                                    <div>
                                        {{ form_label(form.category, null, {label_attr: {class: 'block text-[0.72rem] font-semibold tracking-[0.07em] uppercase text-[#6b6760] mb-1.5' }}) }}
                                        {{ form_widget(form.category, {attr: {
                                                                                class: 'w-full px-3.5 py-2.5 rounded-lg bg-[#0f0e0b] border border-white/[0.1] text-[#e8e4dc] text-[0.88rem] placeholder-[#3a3830] outline-none transition-all focus:border-[#d4860a] focus:ring-2 focus:ring-[#d4860a]/15'
                                                                                }}) }}
                                        <p class="mt-1 text-[0.7rem] text-[#4a4844]">Optional — helps buyers find your product by browsing.</p>
                                    </div>
                                </div>
                            </section>
                            {# ── Section: Pricing & status ── #}
                            <section class="anim d-2 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden">
                                <div class="flex items-center gap-2.5 px-5 py-3.5 border-b border-white/[0.07]">
                                    <div class="w-6 h-6 rounded-md bg-[#1a9e87]/10 grid place-items-center shrink-0">
                                        <svg class="w-3 h-3 text-[#1a9e87]"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="2">
                                            <line x1="12" y1="1" x2="12" y2="23" />
                                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                                        </svg>
                                    </div>
                                    <h2 class="text-[0.82rem] font-semibold text-[#e8e4dc]">Pricing &amp; status</h2>
                                </div>
                                <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-5">
                                    {# Base price #}
                                    <div>
                                        {{ form_label(form.price, null, {label_attr: {class: 'block text-[0.72rem] font-semibold tracking-[0.07em] uppercase text-[#6b6760] mb-1.5' }}) }}
                                        <div class="relative">
                                            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-[0.82rem] text-[#6b6760] font-medium pointer-events-none">₱</span>
                                            {{ form_widget(form.price, {attr: {
                                                                                        class: 'w-full pl-7 pr-3.5 py-2.5 rounded-lg bg-[#0f0e0b] border border-white/[0.1] text-[#e8e4dc] text-[0.88rem] placeholder-[#3a3830] outline-none transition-all focus:border-[#1a9e87] focus:ring-2 focus:ring-[#1a9e87]/15 ' ~ (form.price.vars.errors|length ? 'border-red-500/60' : '')
                                            }}) }}
                                        </div>
                                        {% if form.price.vars.errors|length %}
                                            <p class="mt-1.5 text-[0.75rem] text-red-400 flex items-center gap-1">
                                                <svg class="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="currentColor">
                                                    <path d="M6 0a6 6 0 1 0 0 12A6 6 0 0 0 6 0zm.75 9H5.25V7.5h1.5V9zm0-3H5.25V3h1.5v3z" />
                                                </svg>
                                                {{ form.price.vars.errors|first.message }}
                                            </p>
                                        {% endif %}
                                        <p class="mt-1 text-[0.7rem] text-[#4a4844]">Set your default price. Variants can override this.</p>
                                    </div>
                                    {# Status #}
                                    <div>
                                        {{ form_label(form.status, null, {label_attr: {class: 'block text-[0.72rem] font-semibold tracking-[0.07em] uppercase text-[#6b6760] mb-1.5' }}) }}
                                        {{ form_widget(form.status, {attr: {
                                                                                class: 'w-full px-3.5 py-2.5 rounded-lg bg-[#0f0e0b] border border-white/[0.1] text-[#e8e4dc] text-[0.88rem] outline-none transition-all focus:border-[#1a9e87] focus:ring-2 focus:ring-[#1a9e87]/15 cursor-pointer appearance-none'
                                                                                }}) }}
                                        {% if form.status.vars.errors|length %}
                                            <p class="mt-1.5 text-[0.75rem] text-red-400">{{ form.status.vars.errors|first.message }}</p>
                                        {% endif %}
                                        <p class="mt-1 text-[0.7rem] text-[#4a4844]">Draft saves without publishing. Active goes live immediately.</p>
                                    </div>
                                </div>
                            </section>
                            {# ── Section: Variants ── #}
                            <section class="anim d-3 rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden"
                                     data-controller="variant-manager">
                                <div class="flex items-center justify-between gap-2 px-5 py-3.5 border-b border-white/[0.07]">
                                    <div class="flex items-center gap-2.5">
                                        <div class="w-6 h-6 rounded-md bg-[#3b8bd4]/10 grid place-items-center shrink-0">
                                            <svg class="w-3 h-3 text-[#3b8bd4]"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="2">
                                                <rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" />
                                            </svg>
                                        </div>
                                        <h2 class="text-[0.82rem] font-semibold text-[#e8e4dc]">
                                            Variants
                                            <span class="ml-1 text-[0.72rem] font-normal text-[#6b6760]">(<span data-variant-manager-target="count">0</span>)</span>
                                        </h2>
                                    </div>
                                    <button type="button"
                                            data-action="click->variant-manager#add"
                                            class="inline-flex items-center gap-1.5 text-[0.75rem] font-medium text-[#3b8bd4] hover:text-[#71b3e8] transition-colors cursor-pointer">
                                        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
                                            <path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                                        </svg>
                                        Add variant
                                    </button>
                                </div>
                                {# Variant rows container #}
                                <div data-variant-manager-target="list"
                                     class="divide-y divide-white/[0.07]">
                                    {# Rows inserted dynamically by Stimulus — empty on first load #}
                                </div>
                                {# Empty state (shown when no variants yet) #}
                                <div class="flex items-center gap-3 px-5 py-4 text-[0.8rem] text-[#4a4844]"
                                     id="variant-empty"
                                     data-action="variant-manager:countChanged->variant-manager#_hideEmpty">
                                    <svg class="w-4 h-4 shrink-0 opacity-40"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="1.5">
                                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                                    </svg>
                                    No variants yet. Click <strong class="text-[#3b8bd4] font-medium">Add variant</strong> to specify sizes, colours, or other options.
                                </div>
                                {# Variant row template — cloned by Stimulus #}
                                <template data-variant-manager-target="template">
                                    <div data-variant-row
                                         class="grid grid-cols-[1fr_1fr_80px_32px] items-start gap-3 px-5 py-4">
                                        {# SKU #}
                                        <div>
                                            <label class="block text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-[#6b6760] mb-1">SKU</label>
                                            <input type="text"
                                                   name="variants[__INDEX__][sku]"
                                                   placeholder="SKU-001"
                                                   class="w-full px-3 py-2 rounded-lg bg-[#0f0e0b] border border-white/[0.1] text-[#e8e4dc] text-[0.82rem] placeholder-[#3a3830] outline-none focus:border-[#3b8bd4] focus:ring-1 focus:ring-[#3b8bd4]/20 transition-all">
                                        </div>
                                        {# Attributes #}
                                        <div>
                                            <label class="block text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-[#6b6760] mb-1">Attributes</label>
                                            <input type="text"
                                                   name="variants[__INDEX__][attributes]"
                                                   placeholder="Color: Red, Size: M"
                                                   class="w-full px-3 py-2 rounded-lg bg-[#0f0e0b] border border-white/[0.1] text-[#e8e4dc] text-[0.82rem] placeholder-[#3a3830] outline-none focus:border-[#3b8bd4] focus:ring-1 focus:ring-[#3b8bd4]/20 transition-all">
                                        </div>
                                        {# Price override #}
                                        <div>
                                            <label class="block text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-[#6b6760] mb-1">Price</label>
                                            <div class="relative">
                                                <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-[0.75rem] text-[#6b6760]">₱</span>
                                                <input type="number"
                                                       name="variants[__INDEX__][price]"
                                                       step="0.01"
                                                       min="0"
                                                       placeholder="0.00"
                                                       class="w-full pl-6 pr-2 py-2 rounded-lg bg-[#0f0e0b] border border-white/[0.1] text-[#e8e4dc] text-[0.82rem] placeholder-[#3a3830] outline-none focus:border-[#3b8bd4] focus:ring-1 focus:ring-[#3b8bd4]/20 transition-all">
                                            </div>
                                        </div>
                                        {# Remove #}
                                        <div class="pt-5">
                                            <button type="button"
                                                    data-action="click->variant-manager#remove"
                                                    class="grid place-items-center w-8 h-8 rounded-lg text-[#6b6760] hover:text-red-400 hover:bg-red-500/[0.08] transition-colors cursor-pointer">
                                                <svg class="w-3.5 h-3.5"
                                                     viewBox="0 0 24 24"
                                                     fill="none"
                                                     stroke="currentColor"
                                                     stroke-width="1.8">
                                                    <polyline points="3 6 5 6 21 6" />
                                                    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                                                    <path d="M10 11v6" />
                                                    <path d="M14 11v6" />
                                                    <path d="M9 6V4h6v2" />
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                </template>
                                <div class="px-5 py-3 border-t border-white/[0.07] bg-white/[0.015]">
                                    <p class="text-[0.7rem] text-[#4a4844]">
                                        Each variant gets its own SKU, stock level, and optional price override. Leave price blank to inherit the base price.
                                    </p>
                                </div>
                            </section>
                        </div>
                        {# ── Right: image upload + tips ── #}
                        <div class="space-y-5">
                            {# Image upload card #}
                            <section class="anim rounded-xl bg-[#141210] border border-white/[0.07] overflow-hidden"
                                     data-controller="image-preview">
                                <div class="flex items-center gap-2.5 px-5 py-3.5 border-b border-white/[0.07]">
                                    <div class="w-6 h-6 rounded-md bg-[#e05c4b]/10 grid place-items-center shrink-0">
                                        <svg class="w-3 h-3 text-[#e05c4b]"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="2">
                                            <rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" />
                                        </svg>
                                    </div>
                                    <h2 class="text-[0.82rem] font-semibold text-[#e8e4dc]">Product image</h2>
                                </div>
                                <div class="p-5">
                                    {# Drop zone / preview #}
                                    <label for="{{ form.imageFile.vars.id }}"
                                           class="relative block w-full aspect-square rounded-xl border-2 border-dashed border-white/[0.12] bg-[#0f0e0b] overflow-hidden cursor-pointer hover:border-[#d4860a]/40 transition-colors group">
                                        {# Preview image #}
                                        <img data-image-preview-target="preview"
                                             src="{{ product.image is defined and product.image ? '/uploads/products/' ~ product.image : '' }}"
                                             alt="Product preview"
                                             class="{{ product.image is defined and product.image ? '' : 'hidden' }} absolute inset-0 w-full h-full object-cover">
                                        {# Empty state #}
                                        <div data-image-preview-target="empty"
                                             class="{{ product.image is defined and product.image ? 'hidden' : '' }} absolute inset-0 flex flex-col items-center justify-center gap-3 p-6 text-center">
                                            <div class="w-12 h-12 rounded-xl bg-white/[0.04] grid place-items-center group-hover:bg-[#d4860a]/10 transition-colors">
                                                <svg class="w-6 h-6 text-[#6b6760] group-hover:text-[#d4860a] transition-colors"
                                                     viewBox="0 0 24 24"
                                                     fill="none"
                                                     stroke="currentColor"
                                                     stroke-width="1.5">
                                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                                    <polyline points="17 8 12 3 7 8" /><line x1="12" y1="3" x2="12" y2="15" />
                                                </svg>
                                            </div>
                                            <div>
                                                <p class="text-[0.82rem] font-medium text-[#9c9790] group-hover:text-[#e8e4dc] transition-colors">Click to upload</p>
                                                <p class="text-[0.7rem] text-[#4a4844] mt-0.5">JPG, PNG or WebP · max 5 MB</p>
                                            </div>
                                        </div>
                                        {# Hover overlay when image is loaded #}
                                        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                            <span class="text-[0.75rem] font-medium text-white bg-black/50 px-3 py-1.5 rounded-lg">Replace image</span>
                                        </div>
                                    </label>
                                    {# Hidden file input #}
                                    {{ form_widget(form.imageFile, {attr: {
                                                                        'data-image-preview-target': 'input',
                                                                        'data-action': 'change->image-preview#show',
                                                                        'accept': 'image/jpeg,image/png,image/webp',
                                                                        class: 'sr-only'
                                                                        }}) }}
                                    {# Error #}
                                    {% if form.imageFile.vars.errors|length %}
                                        <p class="mt-2 text-[0.75rem] text-red-400 flex items-center gap-1">
                                            <svg class="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="currentColor">
                                                <path d="M6 0a6 6 0 1 0 0 12A6 6 0 0 0 6 0zm.75 9H5.25V7.5h1.5V9zm0-3H5.25V3h1.5v3z" />
                                            </svg>
                                            {{ form.imageFile.vars.errors|first.message }}
                                        </p>
                                    {% endif %}
                                    {# Clear button #}
                                    <button type="button"
                                            data-action="click->image-preview#clear"
                                            class="mt-3 w-full text-[0.75rem] text-[#6b6760] hover:text-red-400 transition-colors py-2 rounded-lg hover:bg-red-500/[0.06] cursor-pointer">
                                        Remove image
                                    </button>
                                </div>
                            </section>
                            {# Tips card #}
                            <div class="rounded-xl bg-[#141210] border border-white/[0.07] p-5 space-y-3">
                                <h3 class="text-[0.78rem] font-semibold text-[#e8e4dc]">Listing tips</h3>
                                {% for tip in [
                                    {icon:'✅', text:'Use a clean, white-background photo for the main image.'},
                                    {icon:'📝', text:'Write at least 50 words in the description — it helps search ranking.'},
                                    {icon:'💡', text:'Add variants (sizes, colours) to avoid duplicate listings.'},
                                    {icon:'🏷️', text:'Set status to Draft first and preview before going live.'},
                                    ] %}
                                    <div class="flex items-start gap-2.5 text-[0.78rem] text-[#9c9790] leading-relaxed">
                                        <span class="shrink-0 mt-px text-sm">{{ tip.icon }}</span>
                                        {{ tip.text }}
                                    </div>
                                {% endfor %}
                            </div>
                            {# Verification warning if seller not yet verified #}
                            {% if profile and not profile.verified %}
                                <div class="rounded-xl bg-[#d4860a]/[0.06] border border-[#d4860a]/20 p-4">
                                    <div class="flex items-start gap-2.5">
                                        <svg class="w-4 h-4 text-[#f0a832] shrink-0 mt-0.5"
                                             viewBox="0 0 24 24"
                                             fill="none"
                                             stroke="currentColor"
                                             stroke-width="1.8">
                                            <circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" />
                                        </svg>
                                        <div>
                                            <p class="text-[0.78rem] font-medium text-[#f0a832]">Store pending verification</p>
                                            <p class="text-[0.72rem] text-[#6b6760] mt-0.5 leading-relaxed">
                                                You can save products now, but they won't be visible to buyers until your store is verified.
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                    {# /grid #}
                    {# ── Submit bar ── #}
                    <div class="sticky bottom-0 left-0 right-0 mt-8 -mx-5 lg:-mx-8 px-5 lg:px-8 py-4 bg-[#0a0908]/90 border-t border-white/[0.07] backdrop-blur-sm flex items-center justify-between gap-4 flex-wrap">
                        <p class="text-[0.75rem] text-[#4a4844]">
                            {% if editing is defined %}
                                Last updated: <span class="text-[#6b6760]">now</span>
                            {% else %}
                                Product will be saved to <span class="text-[#6b6760]">{{ profile ? profile.store.storeName : 'your store' }}</span>
                            {% endif %}
                        </p>
                        <div class="flex items-center gap-3">
                            <a href="{{ path("app_product_index") }}"
                               class="px-5 py-2.5 rounded-lg text-[0.82rem] text-[#9c9790] hover:text-[#e8e4dc] transition-colors no-underline border border-white/[0.07] hover:border-white/[0.15]">
                                Cancel
                            </a>
                            <button type="submit"
                                    name="_submit_draft"
                                    value="1"
                                    class="px-5 py-2.5 rounded-lg text-[0.82rem] font-medium text-[#0a0908] bg-[#d4860a] hover:bg-[#f0a832] transition-colors cursor-pointer">
                                {{ editing is defined ? 'Save changes' : 'Save product' }} →
                            </button>
                        </div>
                    </div>
                </main>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
