{% extends 'base.html.twig' %}
{% block title %}Hello Seller/ProductController!{% endblock %}
{% block body %}
    <div class="max-w-xl mx-auto p-6">
        <h1 class="text-2xl font-semibold mb-6">Add Product</h1>
        {{ form_start(form, {attr: {class:'space-y-4' }}) }}
            <div>
                {{ form_label(form.name) }}
                {{ form_widget(form.name, {attr:{class:'w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500' }}) }}
                {{ form_errors(form.name) }}
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
