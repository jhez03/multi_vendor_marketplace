# Copy this file to .env.docker and fill in your values.
# This file is read by Docker Compose (not by Symfony directly).
# For local overrides, copy to .env.docker.local (also ignored by git).

###> Symfony App ###
# Use "dev" for local development or "prod" for production deployments.
APP_ENV=dev
APP_SECRET=change_me_to_a_random_32char_string
###< Symfony App ###

###> doctrine/doctrine-bundle ###
# Format: mysql://user:password@host:port/dbname?serverVersion=8.0
DATABASE_URL=mysql://app_user:app_password@db:3306/app_db?serverVersion=8.0&charset=utf8mb4
###< doctrine/doctrine-bundle ###

###> MySQL (used by the db service) ###
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password
###< MySQL ###

###> phpMyAdmin ###
# PMA_HOST is set to "db" in docker-compose.yml; override here only if needed.
# PMA_HOST=db
PMA_PORT=3306
###< phpMyAdmin ###
