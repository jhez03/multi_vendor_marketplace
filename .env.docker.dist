# ============================================================
# Docker Compose environment template
# ============================================================
# Copy this file to .env.docker and fill in real values:
#   cp .env.docker.dist .env.docker
#
# .env.docker          – your local secrets/config (git-ignored)
# .env.docker.local    – optional per-machine overrides (git-ignored)
# .env.docker.dist     – this template (committed to git)
#
# NOTE: These variables are injected into containers by Docker
# Compose.  They are NOT read by Symfony's Dotenv component.
# Symfony picks up APP_ENV / APP_DEBUG / DATABASE_URL etc.
# directly from the process environment that Docker sets up.
# ============================================================

# ── MySQL ────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=marketplace
MYSQL_USER=app
MYSQL_PASSWORD=change_me_app

# ── phpMyAdmin ───────────────────────────────────────────────
PMA_HOST=db
PMA_PORT=3306

# ── Symfony (runtime env vars for the app container) ─────────
APP_ENV=prod
APP_DEBUG=0
# Generate a real secret with: docker compose exec app bin/console secret:generate-keys
# or: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=CHANGE_ME_GENERATE_A_REAL_RANDOM_SECRET

# DATABASE_URL must match MYSQL_USER, MYSQL_PASSWORD, MYSQL_DATABASE, and the service name (db) above.
# If you change any of those values, update this URL accordingly.
# Format: mysql://USER:PASSWORD@HOST:PORT/DBNAME?serverVersion=8.0
DATABASE_URL=mysql://app:change_me_app@db:3306/marketplace?serverVersion=8.0&charset=utf8mb4
